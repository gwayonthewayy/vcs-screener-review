+from __future__ import annotations
+
+import unittest
+from unittest.mock import patch
+
+import pandas as pd
+
+import vcs_screener as core
+
+
+class DownloadOhlcvRetryTests(unittest.TestCase):
+    def test_invalid_crumb_retry_uses_fresh_session(self) -> None:
+        session_calls: list[object] = []
+        reset_calls: list[int] = []
+        download_calls: list[object] = []
+        raw = pd.DataFrame(
+            {
+                "Open": [10.0, 11.0, 12.0],
+                "High": [11.0, 12.0, 13.0],
+                "Low": [9.0, 10.0, 11.0],
+                "Close": [10.5, 11.5, 12.5],
+                "Volume": [1000, 1100, 1200],
+            },
+            index=pd.date_range("2026-06-01", periods=3, freq="D"),
+        )
+
+        def fake_session() -> object:
+            token = object()
+            session_calls.append(token)
+            return token
+
+        def fake_download(*, tickers, period, interval, auto_adjust, progress, threads, session):
+            download_calls.append(session)
+            if len(download_calls) == 1:
+                raise RuntimeError("Invalid Crumb")
+            return raw
+
+        def fake_reset() -> None:
+            reset_calls.append(1)
+
+        with patch.object(core.yf, "download", side_effect=fake_download), patch.object(core, "new_yfinance_session", side_effect=fake_session), patch.object(core, "reset_yfinance_state", side_effect=fake_reset):
+            df, err = core.download_ohlcv("ABC", "3mo", "1d", retries=2, retry_sleep=0.0)
+
+        self.assertIsNotNone(df)
+        self.assertTrue(err == "")
+        self.assertEqual(len(df), 3)
+        self.assertEqual(len(download_calls), 2)
+        self.assertEqual(len(session_calls), 2)
+        self.assertIsNot(session_calls[0], session_calls[1])
+        self.assertEqual(len(reset_calls), 1)
+
+    def test_unknown_failure_is_classified_as_unknown_error(self) -> None:
+        self.assertEqual(core.classify_yfinance_failure("something unexpected"), "unknown_error")
+
+
+if __name__ == "__main__":
+    unittest.main()
