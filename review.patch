+def source_provenance(market: str, *, failed: set[str] | None = None) -> dict[str, object]:
+    market = market.upper()
+    failed = failed or set()
+    required = ["KOSPI", "KOSDAQ"] if market == "KR" else ["NASDAQ", "NYSE", "NYSE_AMERICAN"]
+    return {
+        "market": market,
+        "required_sources": required,
+        "sources": {
+            source: {"ok": source not in failed, "count": 5 if source not in failed else 0, "provider": "fixture"}
+            for source in required
+        },
+    }
+
+
+def universe_frame(size: int = 10, market: str = "KR", *, failed_sources: set[str] | None = None) -> pd.DataFrame:
+    market = market.upper()
+    rows = []
+    for idx in range(size):
+        if market == "KR":
+            symbol = f"{idx:06d}.{'KS' if idx % 2 == 0 else 'KQ'}"
+        else:
+            symbol = f"US{idx}"
+        rows.append(
+            {
+                "market": market,
+                "symbol": symbol,
+                "stock_name": f"Name {idx}",
+                "sector": "Technology",
+            }
+        )
+    frame = pd.DataFrame(rows)
+    frame.attrs["source_provenance"] = source_provenance(market, failed=failed_sources)
+    return frame
+
+
+def liquid_frame(symbols: list[str]) -> pd.DataFrame:
+    return pd.DataFrame(
+        [
+            {
+                "symbol": symbol,
+                "close": 1_500.0 + idx,
+                "average_dollar_volume_20d": 25_000_000.0 + idx,
+                "liquidity_observations": 20,
+            }
+            for idx, symbol in enumerate(symbols)
+        ]
+    )
+
+
+def liquid_frame_with_diagnostics(
+    symbols: list[str],
+    *,
+    reason_counts: dict[str, int] | None = None,
+    batch_reason_counts: dict[str, int] | None = None,
+    batch_failure_count: int = 0,
+    batch_retry_count: int = 0,
+    fallback_symbol_count: int | None = None,
+    recovered_symbol_count: int = 0,
+) -> pd.DataFrame:
+    frame = liquid_frame(symbols)
+    reason_counts = reason_counts or {}
+    batch_reason_counts = batch_reason_counts or {}
+    if fallback_symbol_count is None:
+        fallback_symbol_count = sum(reason_counts.values())
+    frame.attrs["liquidity_diagnostics"] = {
+        "chunk_count": 1,
+        "batch_retry_count": batch_retry_count,
+        "batch_failure_count": batch_failure_count,
+        "fallback_symbol_count": fallback_symbol_count,
+        "recovered_symbol_count": recovered_symbol_count,
+        "final_failure_count": sum(reason_counts.values()),
+        "batch_reason_counts": batch_reason_counts,
+        "reason_counts": reason_counts,
+    }
+    return frame
+
+
+def batch_frame(symbols: list[str], close_start: float = 1_500.0) -> pd.DataFrame:
+    index = pd.date_range("2026-06-01", periods=20, freq="D")
+    columns = pd.MultiIndex.from_product([symbols, ["Close", "Volume"]])
+    data: dict[tuple[str, str], list[float]] = {}
+    for offset, symbol in enumerate(symbols):
+        data[(symbol, "Close")] = [close_start + offset] * len(index)
+        data[(symbol, "Volume")] = [50_000 + offset] * len(index)
+    return pd.DataFrame(data, index=index, columns=columns)
