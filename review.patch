+"""Canonical selection policy shared by VCS briefing outputs.
+
+This module intentionally contains no network or delivery code.  It turns already
+collected market, sector, fundamentals, chart and RS data into deterministic
+selection fields used by markdown, Telegram and TradingView exporters.
+"""
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Mapping, Sequence
+import re
+
+import numpy as np
+import pandas as pd
+
+
+DIRECTNESS_POINTS = {"direct": 10.0, "adjacent": 6.0, "peripheral": 2.0, "unrelated": 0.0}
+EARNINGS_POINTS = {
+    "profitable_expansion": 20.0,
+    "profitable_slowdown": 14.0,
+    "turnaround_positive": 12.0,
+    "loss_narrowing": 5.0,
+    "distorted_or_missing": 0.0,
+}
+PRACTICAL_EARNINGS = {"profitable_expansion", "profitable_slowdown", "turnaround_positive"}
+FRESH_LEADERSHIP_SCOPE = "weekly_liquid_full_market_fresh"
+BIOTECH_PATTERN = re.compile(
+    r"\b(?:biotech(?:nology)?|therapeutics?|clinical[- ]stage|drug development|oncology|rare disease)\b|바이오텍|신약",
+    re.IGNORECASE,
+)
+GENERIC_BUSINESS_TOKENS = {
+    "and", "for", "the", "technology", "technologies", "services", "solutions",
+    "software", "systems", "industrial", "industrials", "business", "company",
+}
+APPROVED_EARNINGS_SOURCES = {
+    "official",
+    "provisional",
+    "preliminary",
+    "dart_filing_date",
+    "dart_provisional_fair_disclosure",
+    "sec_filing_date",
+    "공식",
+    "잠정",
+}
+
+
+@dataclass(frozen=True)
+class RecommendationPolicy:
+    min_vcs: float = 45.0
+    min_sector_leadership_score: float = 60.0
+    max_below_ma50_pct: float = 10.0
+    max_ma50_extension_pct: float = 20.0
+    max_earnings_age_days: int = 180
+    max_atrp: float = 9.0
+    fresh_leadership_scopes: tuple[str, ...] = (FRESH_LEADERSHIP_SCOPE,)
+
+
+@dataclass(frozen=True)
+class BusinessMatch:
+    business_directness: str
+    matched_lead_sector: str
+    sector_leadership_score: float | None
+    needs_sector_review: bool
+    match_reason: str
+
+
+@dataclass(frozen=True)
+class EarningsAssessment:
+    quality: str
+    verified: bool
+    quarter: str
+    release_date: str
+    source_type: str
+    age_days: int | None
+    reason: str
+
+
+@dataclass(frozen=True)
+class MarketExposure:
+    signal: str
+    score: float
+    exposure_multiplier: float
+    reasons: tuple[str, ...]
+
+
+def _clean(value: object) -> str:
+    if value is None or (isinstance(value, float) and pd.isna(value)):
+        return ""
+    return " ".join(str(value).split())
+
+
+def _number(value: object) -> float | None:
+    try:
+        number = float(value)
+    except (TypeError, ValueError):
+        return None
+    return None if pd.isna(number) else number
+
+
+def _boolean(value: object) -> bool | None:
+    if value is None or (isinstance(value, float) and pd.isna(value)):
+        return None
+    if isinstance(value, (bool, np.bool_)):
+        return bool(value)
+    text = str(value).strip().lower()
+    if text in {"true", "1", "yes", "y", "t"}:
+        return True
+    if text in {"false", "0", "no", "n", "f"}:
+        return False
+    return None
+
+
+def _normalized_source_type(value: object) -> str:
+    text = _clean(value).lower()
+    text = text.replace("-", "_").replace(" ", "_")
+    text = re.sub(r"_+", "_", text)
+    return text.strip("_")
+
+
+def _tokens(value: object) -> set[str]:
+    return {
+        token
+        for token in re.findall(r"[a-z0-9가-힣]+", _clean(value).replace("_", " ").replace("/", " ").lower())
+        if len(token) > 2 and token not in GENERIC_BUSINESS_TOKENS
+    }
+
+
+def _evidence_text(row: pd.Series, fields: Sequence[str]) -> str:
+    return " ".join(_clean(row.get(field)) for field in fields if _clean(row.get(field))).lower()
+
+
+def _risk_business_text(row: pd.Series) -> str:
+    return _evidence_text(
+        row,
+        (
+            "sector", "sector_detail", "sector_theme_group", "industry", "business_summary",
+            "longBusinessSummary", "business_description", "description", "theme_hint", "business_tags",
+        ),
+    )
+
+
+def _canonical_evidence(text: str) -> set[str]:
+    evidence: set[str] = set()
+    rules: dict[str, Sequence[str]] = {
+        "semiconductors": ("semiconductor", "chip design", "rf chip", "hbm", "반도체", "웨이퍼", "파운드리"),
+        "ai infrastructure": ("ai accelerator", "gpu server", "data center networking", "artificial intelligence infrastructure", "ai infrastructure", "ai 인프라"),
+        "software": ("saas", "cloud software", "enterprise software", "cybersecurity", "application software"),
+        "shipbuilding": ("shipbuilding", "shipyard", "조선", "선박", "특수선"),
+        "power infrastructure": ("transformer", "power grid", "switchgear", "전력기기", "변압기", "전력망"),
+        "biotechnology": ("biotech", "biotechnology", "therapeutics", "clinical-stage", "바이오텍", "신약"),
+    }
+    for label, phrases in rules.items():
+        if any(phrase in text for phrase in phrases):
+            evidence.add(label)
+    return evidence
+
+
+def _customer_only_business_context(text: str) -> bool:
+    patterns = (
+        r"\bservices?\s+to\b",
+        r"\bcustomers?\s+include\b",
+        r"\bconsulting to\b",
+        r"\blogistics for\b",
+        r"\binsurance products for\b",
+        r"\bserves?\b.*\b(?:manufacturers?|makers?|operators?|companies?|customers?)\b",
+        r"\bprovides?\b.*\b(?:services?|solutions?|products?)\s+for\b",
+        r"\bprovider[s]?\s+to\b",
+    )
+    return any(re.search(pattern, text) for pattern in patterns)
+
+
+def classify_business_directness(row: pd.Series, leadership: pd.DataFrame) -> BusinessMatch:
+    """Match real business evidence only against sectors that are currently leading."""
+    if leadership is None or leadership.empty or "sector" not in leadership.columns:
+        return BusinessMatch("unrelated", "", None, True, "sector leadership unavailable")
+
+    leaders = leadership.copy()
+    leaders["leadership_score"] = pd.to_numeric(leaders.get("leadership_score"), errors="coerce")
+    leaders = leaders.dropna(subset=["leadership_score"]).sort_values("leadership_score", ascending=False)
+    if leaders.empty:
+        return BusinessMatch("unrelated", "", None, True, "sector leadership score unavailable")
+
+    primary_structured = _evidence_text(row, ("industry", "business_tags"))
+    primary_description = _evidence_text(
+        row,
+        ("business_summary", "longBusinessSummary", "business_description", "description"),
+    )
+    primary_text = " ".join(part for part in (primary_structured, primary_description) if part)
+    auxiliary_text = _evidence_text(row, ("sector", "sector_detail", "sector_theme_group", "theme_hint"))
+    primary_tokens = _tokens(primary_text)
+    primary_evidence = _canonical_evidence(primary_text)
+    auxiliary_tokens = _tokens(auxiliary_text)
+    auxiliary_evidence = _canonical_evidence(auxiliary_text)
+    description_customer_only = _customer_only_business_context(primary_description)
+    generic_overlap_seen = False
+
+    best: tuple[int, float, BusinessMatch] | None = None
+    for _, leader in leaders.iterrows():
+        sector = _clean(leader.get("sector"))
+        if not sector:
+            continue
+        score = float(leader["leadership_score"])
+        sector_lower = sector.lower()
+        leader_tokens = _tokens(sector_lower)
+        canonical = _canonical_evidence(sector_lower)
+
+        sector_tokens = _tokens(sector_lower)
+        exact_structured = bool(sector_tokens) and all(token in primary_structured for token in sector_tokens)
+        canonical_match = bool(canonical & primary_evidence) and not description_customer_only
+        specific_overlap = leader_tokens & primary_tokens
+        auxiliary_match = bool(canonical & auxiliary_evidence) or bool(leader_tokens & auxiliary_tokens)
+        generic_overlap_seen = generic_overlap_seen or bool(_tokens(sector) & primary_tokens)
+
+        if exact_structured or canonical_match:
+            result = BusinessMatch("direct", sector, score, False, "structured industry/business evidence matches current leader")
+            rank = 4
+        elif len(specific_overlap) >= 2:
+            result = BusinessMatch("adjacent", sector, score, False, "multiple specific business terms overlap current leader")
+            rank = 3
+        elif specific_overlap:
+            result = BusinessMatch("peripheral", sector, score, True, "single business-term overlap needs review")
+            rank = 2
+        elif auxiliary_match:
+            result = BusinessMatch("peripheral", sector, score, True, "theme or generic sector label is auxiliary evidence only")
+            rank = 1
+        else:
+            continue
+        candidate = (rank, score, result)
+        if best is None or candidate[:2] > best[:2]:
+            best = candidate
+
+    if best is not None:
+        return best[2]
+    reason = "generic technology wording is not direct business evidence" if generic_overlap_seen or "technology" in primary_text else "no business evidence matches a current leader"
+    return BusinessMatch("unrelated", "", None, True, reason)
+
+
+def _first(row: pd.Series, names: Sequence[str]) -> object:
+    for name in names:
+        value = row.get(name)
+        if value is not None and not (isinstance(value, float) and pd.isna(value)) and _clean(value):
+            return value
+    return None
+
+
+def classify_earnings_quality(
+    row: pd.Series,
+    *,
+    as_of: pd.Timestamp | None = None,
+    max_age_days: int = 180,
+) -> EarningsAssessment:
+    as_of = pd.Timestamp(as_of or pd.Timestamp.now())
+    as_of = as_of.tz_localize("UTC") if as_of.tzinfo is None else as_of.tz_convert("UTC")
+    quarter = _clean(_first(row, ("earnings_quarter", "announced_quarter", "earnings_quarter_end", "quarter_end", "latest_quarter")))
+    release_raw = _first(row, ("earnings_release_date", "release_date", "announced_release_date"))
+    source = _normalized_source_type(_first(row, ("earnings_source_type", "earnings_release_source", "release_source", "earnings_basis")))
+    release = pd.to_datetime(release_raw, errors="coerce", utc=True)
+    age_days = None if pd.isna(release) else int((as_of - release).days)
+    source_verified = source in APPROVED_EARNINGS_SOURCES
+
+    quarter_match = re.fullmatch(r"(\d{4})\s*[- ]?Q([1-4])", quarter, flags=re.IGNORECASE)
+    if quarter_match:
+        quarter_end = pd.Period(
+            year=int(quarter_match.group(1)),
+            quarter=int(quarter_match.group(2)),
+            freq="Q",
+        ).end_time.normalize().tz_localize("UTC")
+    else:
+        quarter_end = pd.to_datetime(quarter, errors="coerce", utc=True)
+        quarter_end = quarter_end.normalize() if not pd.isna(quarter_end) else quarter_end
+
+    metadata_reason = ""
+    if not quarter or pd.isna(quarter_end):
+        metadata_reason = "missing or invalid earnings quarter"
+    elif pd.isna(release):
+        metadata_reason = "missing or invalid earnings release date"
+    elif release > as_of:
+        metadata_reason = "future earnings release date"
+    elif quarter_end > release or (release - quarter_end).days > 370:
+        metadata_reason = "earnings quarter and release date are not plausibly linked"
+    elif not source_verified:
+        metadata_reason = "earnings source is not official or provisional"
+    elif age_days is None or age_days < 0 or age_days > max_age_days:
+        metadata_reason = "missing or stale earnings release metadata"
+
+    revenue = _number(_first(row, ("revenue_current", "announced_revenue_current", "quarter_revenue")))
+    latest = _number(row.get("opm_latest_q"))
+    one_year = _number(row.get("opm_roll4q"))
+    three_year = _number(row.get("opm_roll12q"))
+    metadata_ok = not metadata_reason
+    values_ok = revenue is not None and revenue > 0 and latest is not None and one_year is not None and three_year is not None
+    if not metadata_ok or not values_ok:
+        reason = metadata_reason if not metadata_ok else "revenue or OPM missing/distorted"
+        return EarningsAssessment(
+            "distorted_or_missing", False, quarter, "" if pd.isna(release) else release.date().isoformat(),
+            source, age_days, reason,
+        )
+
+    if latest < 0 and one_year < 0 and three_year < 0:
+        quality = "loss_narrowing" if latest > one_year > three_year else "distorted_or_missing"
+    elif latest >= 0 and one_year <= 0:
+        quality = "turnaround_positive"
+    elif latest > 0 and one_year > 0 and three_year > 0 and latest >= one_year > three_year:
+        quality = "profitable_expansion"
+    elif latest > 0 and one_year > 0 and three_year > 0:
+        quality = "profitable_slowdown"
+    else:
+        quality = "distorted_or_missing"
+    verified = quality != "distorted_or_missing"
+    return EarningsAssessment(
+        quality, verified, quarter, release.date().isoformat(), source, age_days,
+        "latest reported quarter classified from revenue and OPM history",
+    )
