+def valid_snapshot(market: str, refreshed_at: str | None = None) -> pd.DataFrame:
+    market = market.upper()
+    required = ["KOSPI", "KOSDAQ"] if market == "KR" else ["NASDAQ", "NYSE", "NYSE_AMERICAN"]
+    symbols = ["005930.KS", "247540.KQ"] if market == "KR" else ["MTSI", "EBAY"]
+    source_status = {
+        source: {"ok": True, "count": 1, "provider": "fixture"}
+        for source in required
+    }
+    timestamp = refreshed_at or datetime.now(timezone.utc).isoformat()
+    return pd.DataFrame(
+        {
+            "market": [market] * 2,
+            "symbol": symbols,
+            "universe_scope": ["weekly_liquid_full_market"] * 2,
+            "universe_refreshed_at": [timestamp] * 2,
+            "universe_symbol_count": [2] * 2,
+            "liquid_symbol_count": [2] * 2,
+            "liquidity_coverage_pct": [100.0] * 2,
+            "universe_required_sources": [json.dumps(required)] * 2,
+            "universe_source_status": [json.dumps(source_status)] * 2,
+            "universe_required_source_count": [len(required)] * 2,
+            "universe_successful_source_count": [len(required)] * 2,
+        }
