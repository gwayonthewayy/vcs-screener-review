@@ -0,0 +1,223 @@
+"""Strict validation contracts for weekly leadership-universe snapshots."""
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import datetime, timezone
+import json
+from pathlib import Path
+from typing import Mapping
+
+import pandas as pd
+
+
+WEEKLY_FULL_MARKET_SCOPE = "weekly_liquid_full_market"
+WEEKLY_FRESH_SCOPE = "weekly_liquid_full_market_fresh"
+WEEKLY_STALE_SCOPE = "stale_cached_market_context"
+WEEKLY_FALLBACK_SCOPE = "candidate_fallback_not_full_market"
+DEFAULT_FRESH_DAYS = 10
+DEFAULT_STALE_DAYS = 21
+
+EXPECTED_REQUIRED_SOURCES = {
+    "KR": ("KOSPI", "KOSDAQ"),
+    "US": ("NASDAQ", "NYSE", "NYSE_AMERICAN"),
+}
+
+REQUIRED_SNAPSHOT_COLUMNS = {
+    "market",
+    "symbol",
+    "universe_scope",
+    "universe_refreshed_at",
+    "universe_symbol_count",
+    "liquid_symbol_count",
+    "liquidity_coverage_pct",
+    "universe_required_sources",
+    "universe_source_status",
+    "universe_required_source_count",
+    "universe_successful_source_count",
+}
+
+
+@dataclass(frozen=True)
+class SnapshotAssessment:
+    status: str
+    scope: str
+    reason: str
+    refreshed_at: pd.Timestamp | None = None
+    age_days: float | None = None
+
+    @property
+    def usable(self) -> bool:
+        return self.status in {"fresh", "stale"}
+
+
+def _single_value(frame: pd.DataFrame, column: str) -> object:
+    series = frame[column]
+    if series.isna().any():
+        raise ValueError(f"{column} must contain one non-empty value in every row")
+    values = series.astype(str).map(str.strip).tolist()
+    if any(not value for value in values):
+        raise ValueError(f"{column} must contain one non-empty value in every row")
+    unique = pd.Series(values, dtype="object").unique().tolist()
+    if len(unique) != 1:
+        raise ValueError(f"{column} must contain one non-empty value")
+    return unique[0]
+
+
+def _positive_int(value: object, label: str) -> int:
+    number = pd.to_numeric(pd.Series([value]), errors="coerce").iloc[0]
+    if pd.isna(number) or float(number) <= 0 or not float(number).is_integer():
+        raise ValueError(f"{label} must be a positive integer")
+    return int(number)
+
+
+def _coverage(value: object) -> float:
+    number = pd.to_numeric(pd.Series([value]), errors="coerce").iloc[0]
+    if pd.isna(number) or not 0 < float(number) <= 100:
+        raise ValueError("liquidity_coverage_pct must be in (0, 100]")
+    return float(number)
+
+
+def validate_source_provenance(market: str, provenance: object) -> tuple[bool, str]:
+    market = str(market).upper()
+    expected = set(EXPECTED_REQUIRED_SOURCES.get(market, ()))
+    if not expected:
+        return False, f"unsupported market provenance: {market}"
+    if not isinstance(provenance, Mapping):
+        return False, "source provenance metadata missing"
+    if str(provenance.get("market", "")).upper() != market:
+        return False, f"source provenance market mismatch for {market}"
+    required_raw = provenance.get("required_sources")
+    if not isinstance(required_raw, (list, tuple)):
+        return False, "required source list missing"
+    required = {str(item) for item in required_raw if str(item)}
+    if required != expected:
+        missing = sorted(expected - required)
+        extra = sorted(required - expected)
+        return False, f"required source set mismatch missing={missing} extra={extra}"
+    sources = provenance.get("sources")
+    if not isinstance(sources, Mapping):
+        return False, "source status map missing"
+    failed: list[str] = []
+    for source in sorted(expected):
+        status = sources.get(source)
+        if not isinstance(status, Mapping):
+            failed.append(f"{source}:missing")
+            continue
+        count = pd.to_numeric(pd.Series([status.get("count")]), errors="coerce").iloc[0]
+        if status.get("ok") is not True or pd.isna(count) or float(count) <= 0:
+            failed.append(f"{source}:failed")
+    if failed:
+        return False, "required source failure: " + ", ".join(failed)
+    return True, "ok"
+
+
+def snapshot_source_columns(provenance: Mapping[str, object]) -> dict[str, object]:
+    required = [str(item) for item in provenance.get("required_sources", [])]
+    sources = provenance.get("sources", {})
+    successful = sum(
+        1
+        for source in required
+        if isinstance(sources, Mapping)
+        and isinstance(sources.get(source), Mapping)
+        and sources[source].get("ok") is True
+    )
+    return {
+        "universe_required_sources": json.dumps(required, ensure_ascii=False, sort_keys=True),
+        "universe_source_status": json.dumps(sources, ensure_ascii=False, sort_keys=True),
+        "universe_required_source_count": len(required),
+        "universe_successful_source_count": successful,
+    }
+
+
+def assess_weekly_universe_snapshot(
+    path: Path,
+    market: str,
+    *,
+    now: datetime | pd.Timestamp | None = None,
+    fresh_days: int = DEFAULT_FRESH_DAYS,
+    stale_days: int = DEFAULT_STALE_DAYS,
+) -> SnapshotAssessment:
+    market = str(market).upper()
+    try:
+        frame = pd.read_csv(path, encoding="utf-8-sig")
+    except Exception as exc:
+        return SnapshotAssessment("invalid", WEEKLY_FALLBACK_SCOPE, f"snapshot unreadable: {exc}")
+    if frame.empty:
+        return SnapshotAssessment("invalid", WEEKLY_FALLBACK_SCOPE, "snapshot CSV is empty")
+    missing = sorted(REQUIRED_SNAPSHOT_COLUMNS - set(frame.columns))
+    if missing:
+        return SnapshotAssessment("invalid", WEEKLY_FALLBACK_SCOPE, f"snapshot schema missing: {', '.join(missing)}")
+
+    try:
+        market_value = str(_single_value(frame, "market")).upper()
+        if market_value != market:
+            raise ValueError(f"market rows mismatch: {market_value}")
+        scope_value = str(_single_value(frame, "universe_scope"))
+        if scope_value != WEEKLY_FULL_MARKET_SCOPE:
+            raise ValueError(f"universe_scope must be {WEEKLY_FULL_MARKET_SCOPE}")
+        symbols = frame["symbol"].astype(str).str.strip()
+        if frame["symbol"].isna().any() or symbols.eq("").any():
+            raise ValueError("symbol rows must be non-empty and unique")
+        unique_symbols = int(symbols.nunique())
+        if unique_symbols <= 0 or unique_symbols != len(frame):
+            raise ValueError("symbol rows must be non-empty and unique")
+
+        refreshed_text = str(_single_value(frame, "universe_refreshed_at"))
+        timestamps = pd.to_datetime(
+            pd.Series([refreshed_text]),
+            errors="coerce",
+            utc=True,
+            format="mixed",
+        )
+        if timestamps.isna().any():
+            raise ValueError("universe_refreshed_at must contain one parseable timestamp")
+        refreshed = timestamps.iloc[0]
+        current = pd.Timestamp(now or datetime.now(timezone.utc))
+        current = current.tz_localize("UTC") if current.tzinfo is None else current.tz_convert("UTC")
+        if refreshed > current:
+            raise ValueError("universe_refreshed_at is in the future")
+
+        universe_count = _positive_int(_single_value(frame, "universe_symbol_count"), "universe_symbol_count")
+        liquid_count = _positive_int(_single_value(frame, "liquid_symbol_count"), "liquid_symbol_count")
+        coverage_pct = _coverage(_single_value(frame, "liquidity_coverage_pct"))
+        if liquid_count != unique_symbols:
+            raise ValueError(f"liquid_symbol_count {liquid_count} != CSV symbols {unique_symbols}")
+        if universe_count < liquid_count:
+            raise ValueError("universe_symbol_count is below liquid_symbol_count")
+        calculated_coverage = liquid_count / universe_count * 100.0
+        if abs(calculated_coverage - coverage_pct) > 0.11:
+            raise ValueError("liquidity coverage metadata is inconsistent with counts")
+
+        required_sources = json.loads(str(_single_value(frame, "universe_required_sources")))
+        source_status = json.loads(str(_single_value(frame, "universe_source_status")))
+        required_count = _positive_int(
+            _single_value(frame, "universe_required_source_count"),
+            "universe_required_source_count",
+        )
+        successful_count = _positive_int(
+            _single_value(frame, "universe_successful_source_count"),
+            "universe_successful_source_count",
+        )
+        provenance = {
+            "market": market,
+            "required_sources": required_sources,
+            "sources": source_status,
+        }
+        provenance_ok, provenance_reason = validate_source_provenance(market, provenance)
+        if not provenance_ok:
+            raise ValueError(provenance_reason)
+        if required_count != len(required_sources) or successful_count != required_count:
+            raise ValueError("required/successful source count metadata is inconsistent")
+    except Exception as exc:
+        return SnapshotAssessment("invalid", WEEKLY_FALLBACK_SCOPE, str(exc))
+
+    age_days = (current - refreshed).total_seconds() / 86_400.0
+    if age_days <= fresh_days:
+        return SnapshotAssessment("fresh", WEEKLY_FRESH_SCOPE, "fresh validated weekly snapshot", refreshed, age_days)
+    if age_days <= stale_days:
+        return SnapshotAssessment("stale", WEEKLY_STALE_SCOPE, "validated weekly snapshot is stale", refreshed, age_days)
+    return SnapshotAssessment("expired", WEEKLY_FALLBACK_SCOPE, "weekly snapshot exceeds stale limit", refreshed, age_days)
+
+
+def is_fresh_full_market_scope(scope: object) -> bool:
+    return str(scope) == WEEKLY_FRESH_SCOPE
