+++ b/candidate_enrichment_v2.py
@@ -0,0 +1,241 @@
+"""Data enrichment used immediately before briefing candidate selection."""
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Callable
+import re
+
+import numpy as np
+import pandas as pd
+
+from briefing_logic_v2 import (
+    FRESH_LEADERSHIP_SCOPE,
+    classify_business_directness,
+    classify_earnings_quality,
+    enrich_recommendations,
+)
+from kr_index_sources import naver_index_history
+from relative_strength import RSConfig, calc_rs_metrics
+
+try:
+    import yfinance as yf
+except Exception:  # pragma: no cover - runtime dependency
+    yf = None
+
+
+RS_OUTPUT_COLUMNS = [
+    "rs_benchmark", "rs_benchmark_source", "rs_score", "rs_above_ma", "rs_mom_5d",
+    "rs_mom_21d", "rs_new_high", "rs_new_high_before_price", "rs_method", "rs_confidence",
+    "rs_line", "rs_ma", "rs_ma_gap_pct", "rs_asof",
+]
+
+
+def leadership_scope_for_frame(leadership: pd.DataFrame) -> str:
+    if leadership is None or leadership.empty or "leadership_universe_scope" not in leadership.columns:
+        return "unknown"
+    values = leadership["leadership_universe_scope"].dropna().astype(str).map(str.strip)
+    values = values[values != ""]
+    if values.empty:
+        return "unknown"
+    return values.iloc[0]
+
+
+def benchmark_for_symbol(symbol: str, market: str) -> tuple[str, str | None]:
+    symbol = str(symbol).upper()
+    if market.upper() == "KR":
+        return ("KOSDAQ", None) if symbol.endswith(".KQ") else ("KOSPI", None)
+    return "QQQ", "SPY"
+
+
+def _history(symbol: str, period: str = "2y") -> pd.DataFrame:
+    if yf is None:
+        return pd.DataFrame()
+    try:
+        return yf.Ticker(symbol).history(period=period, interval="1d", auto_adjust=False)
+    except Exception:
+        return pd.DataFrame()
+
+
+def _benchmark_history(label: str) -> tuple[pd.DataFrame, str]:
+    if label == "KOSPI":
+        ticker = "^KS11"
+    elif label == "KOSDAQ":
+        ticker = "^KQ11"
+    else:
+        ticker = label
+    frame = _history(ticker)
+    if not frame.empty:
+        return frame, f"yfinance:{ticker}"
+    if label in {"KOSPI", "KOSDAQ"}:
+        try:
+            frame = naver_index_history(ticker)
+        except Exception:
+            frame = pd.DataFrame()
+        if not frame.empty:
+            return frame, f"naver:{ticker}"
+    return pd.DataFrame(), "unavailable"
+
+
+def _confidence(stock: pd.DataFrame, benchmark: pd.DataFrame) -> str:
+    if stock.empty or benchmark.empty:
+        return "unavailable"
+    stock_index = pd.DatetimeIndex(stock.index).normalize()
+    benchmark_index = pd.DatetimeIndex(benchmark.index).normalize()
+    aligned = len(stock_index.intersection(benchmark_index))
+    return "high" if aligned >= 252 else "medium" if aligned >= 126 else "low"
+
+
+def _empty_rs(label: str, source: str = "unavailable") -> dict[str, object]:
+    return {
+        "rs_benchmark": label,
+        "rs_benchmark_source": source,
+        "rs_score": np.nan,
+        "rs_above_ma": pd.NA,
+        "rs_mom_5d": np.nan,
+        "rs_mom_21d": np.nan,
+        "rs_new_high": pd.NA,
+        "rs_new_high_before_price": pd.NA,
+        "rs_method": "relative_line_ema21_percentile_proxy",
+        "rs_confidence": "unavailable",
+        "rs_line": np.nan,
+        "rs_ma": np.nan,
+        "rs_ma_gap_pct": np.nan,
+        "rs_asof": "",
+    }
+
+
+def enrich_relative_strength(
+    df: pd.DataFrame,
+    *,
+    cache_path: Path | None = None,
+    history_loader: Callable[[str], pd.DataFrame] | None = None,
+) -> pd.DataFrame:
+    if df.empty:
+        return df.copy()
+    loader = history_loader or _history
+    cache = pd.DataFrame()
+    if cache_path is not None and cache_path.exists():
+        try:
+            cache = pd.read_csv(cache_path, encoding="utf-8-sig")
+        except Exception:
+            cache = pd.DataFrame()
+    cached = cache.drop_duplicates("symbol", keep="last").set_index("symbol") if "symbol" in cache.columns else pd.DataFrame()
+
+    benchmark_cache: dict[str, tuple[pd.DataFrame, str]] = {}
+    rows: list[dict[str, object]] = []
+    for _, source_row in df.iterrows():
+        row = source_row.to_dict()
+        symbol = str(row.get("symbol", "")).strip()
+        market = str(row.get("market", "US")).upper()
+        if not cached.empty and symbol in cached.index:
+            cached_row = cached.loc[symbol]
+            if isinstance(cached_row, pd.DataFrame):
+                cached_row = cached_row.iloc[-1]
+            if str(cached_row.get("rs_asof", "")) == str(row.get("date", "")) and pd.notna(cached_row.get("rs_score")):
+                for column in RS_OUTPUT_COLUMNS:
+                    row[column] = cached_row.get(column)
+                rows.append(row)
+                continue
+
+        benchmark_label, fallback = benchmark_for_symbol(symbol, market)
+        if benchmark_label not in benchmark_cache:
+            benchmark_cache[benchmark_label] = _benchmark_history(benchmark_label)
+        benchmark, benchmark_source = benchmark_cache[benchmark_label]
+        if benchmark.empty and fallback:
+            if fallback not in benchmark_cache:
+                benchmark_cache[fallback] = _benchmark_history(fallback)
+            benchmark, benchmark_source = benchmark_cache[fallback]
+            benchmark_label = fallback
+
+        stock = loader(symbol)
+        if stock.empty or benchmark.empty:
+            metrics = _empty_rs(benchmark_label, benchmark_source)
+        else:
+            metrics = calc_rs_metrics(stock, benchmark, RSConfig(benchmark_label=benchmark_label))
+            metrics.update(
+                {
+                    "rs_benchmark_source": benchmark_source,
+                    "rs_method": "relative_line_ema21_percentile_proxy",
+                    "rs_confidence": _confidence(stock, benchmark),
+                    "rs_asof": str(row.get("date", "")) or pd.Timestamp(stock.index[-1]).date().isoformat(),
+                }
+            )
+        row.update({column: metrics.get(column) for column in RS_OUTPUT_COLUMNS})
+        rows.append(row)
+
+    out = pd.DataFrame(rows)
+    if cache_path is not None:
+        cache_path.parent.mkdir(parents=True, exist_ok=True)
+        cache_rows = out[["symbol", *RS_OUTPUT_COLUMNS]].drop_duplicates("symbol", keep="last")
+        cache_rows.to_csv(cache_path, index=False, encoding="utf-8-sig")
+    return out
+
+
+def enrich_earnings_quality(df: pd.DataFrame, *, as_of: pd.Timestamp | None = None) -> pd.DataFrame:
+    if df.empty:
+        return df.copy()
+    out = df.copy()
+    assessments = [classify_earnings_quality(row, as_of=as_of) for _, row in out.iterrows()]
+    out["earnings_quality"] = [item.quality for item in assessments]
+    out["earnings_verified"] = [item.verified for item in assessments]
+    out["earnings_quarter"] = [item.quarter for item in assessments]
+    out["earnings_release_date"] = [item.release_date for item in assessments]
+    out["earnings_source_type"] = [item.source_type for item in assessments]
+    out["earnings_age_days"] = [item.age_days for item in assessments]
+    out["earnings_quality_reason"] = [item.reason for item in assessments]
+    return out
+
+
+def enrich_business_directness(df: pd.DataFrame, leadership: pd.DataFrame) -> pd.DataFrame:
+    if df.empty:
+        return df.copy()
+    out = df.copy()
+    scope = leadership_scope_for_frame(leadership)
+    out["leadership_universe_scope"] = scope
+    out["leadership_scope_is_fresh"] = scope == FRESH_LEADERSHIP_SCOPE
+    matches = [classify_business_directness(row, leadership) for _, row in out.iterrows()]
+    out["business_directness"] = [item.business_directness for item in matches]
+    out["matched_lead_sector"] = [item.matched_lead_sector for item in matches]
+    out["assigned_lead_sector"] = out["matched_lead_sector"]
+    out["sector_leadership_score"] = [item.sector_leadership_score for item in matches]
+    out["needs_sector_review"] = [item.needs_sector_review for item in matches]
+    out["business_match_reason"] = [item.match_reason for item in matches]
+
+    biotech = out.apply(
+        lambda row: bool(
+            re.search(
+                r"biotech|biotechnology|therapeutics|clinical-stage|바이오텍|신약",
+                " ".join(str(row.get(col, "")) for col in ("industry", "sector_detail", "business_summary")),
+                re.IGNORECASE,
+            )
+        ),
+        axis=1,
+    )
+    out["leadership_bucket"] = out["business_directness"].map(
+        {"direct": "주도 섹터 본류", "adjacent": "인접 테마", "peripheral": "개별 실적주", "unrelated": "비주도/관찰"}
+    )
+    out.loc[biotech, "leadership_bucket"] = "비주도/고위험"
+    out["leadership_theme"] = out["matched_lead_sector"].where(out["matched_lead_sector"].astype(str).str.len() > 0, out.get("sector_detail", "미분류"))
+    out.loc[biotech, "leadership_theme"] = "바이오텍"
+    return out
+
+
+def prepare_candidates(
+    df: pd.DataFrame,
+    *,
+    leadership: pd.DataFrame,
+    rs_cache_path: Path | None = None,
+    fetch_rs: bool = True,
+    chart_enricher: Callable[[pd.DataFrame], pd.DataFrame] | None = None,
+) -> pd.DataFrame:
+    out = enrich_earnings_quality(df)
+    out = enrich_business_directness(out, leadership)
+    if fetch_rs:
+        out = enrich_relative_strength(out, cache_path=rs_cache_path)
+    else:
+        for column in RS_OUTPUT_COLUMNS:
+            if column not in out.columns:
+                out[column] = pd.NA
+    if chart_enricher is not None:
+        out = chart_enricher(out)
+    return enrich_recommendations(out)
