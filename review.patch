+#!/usr/bin/env python3
+"""Refresh independent liquid universes and rolling daily watchlists.
+
+This is intentionally not scheduled here.  Run it weekly before the daily
+pipeline so sector leadership is measured independently from VCS candidates.
+"""
+from __future__ import annotations
+
+import argparse
+import os
+import shutil
+import sys
+import time
+from collections import Counter
+from datetime import datetime, timezone
+from pathlib import Path
+import tempfile
+from typing import Callable, Mapping
+
+import pandas as pd
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+if str(REPO_ROOT) not in sys.path:
+    sys.path.insert(0, str(REPO_ROOT))
+
+from full_market_scan import get_kr_universe, get_us_universe
+from add_kr_detailed_theme import detail_for_row, theme_group_for_detail
+from us_sector_leadership import enrich_sector_info
+import vcs_screener as core
+from weekly_universe_cache import (
+    WEEKLY_FULL_MARKET_SCOPE,
+    assess_weekly_universe_snapshot,
+    snapshot_source_columns,
+    validate_source_provenance,
+)
+
+try:
+    import yfinance as yf
+except Exception:  # pragma: no cover
+    yf = None
+
+
+DEFAULT_MIN_SYMBOLS = 20
+DEFAULT_MIN_COVERAGE_PCT = 70.0
+DEFAULT_LIQUIDITY_CHUNK_SIZE = 120
+DEFAULT_LIQUIDITY_BATCH_RETRIES = 2
+DEFAULT_LIQUIDITY_SYMBOL_RETRIES = 2
+DEFAULT_LIQUIDITY_RETRY_SLEEP = 0.75
+PERMANENT_LIQUIDITY_FAILURE_REASONS = {
+    "possibly_delisted",
+    "invalid_ticker_mapping",
+    "no_price_data",
+    "empty_response",
+}
+ANALYSIS_READY_LIQUIDITY_RATIO = 0.5
+
+
+def _row_from_frame(symbol: str, frame: pd.DataFrame | None) -> tuple[dict[str, object] | None, str]:
+    if frame is None or frame.empty:
+        return None, "empty_response"
+    close = pd.to_numeric(frame.get("Close"), errors="coerce")
+    volume = pd.to_numeric(frame.get("Volume"), errors="coerce")
+    valid = pd.DataFrame({"close": close, "volume": volume}).dropna().tail(20)
+    if valid.empty:
+        return None, "empty_response"
+    return (
+        {
+            "symbol": symbol,
+            "close": float(valid["close"].iloc[-1]),
+            "average_dollar_volume_20d": float((valid["close"] * valid["volume"]).mean()),
+            "liquidity_observations": len(valid),
+        },
+        "",
+    )
+
+
+def _frame_from_raw(raw: pd.DataFrame | None, symbol: str, group_size: int) -> pd.DataFrame | None:
+    if raw is None or raw.empty:
+        return None
+    if isinstance(raw.columns, pd.MultiIndex):
+        if symbol not in raw.columns.get_level_values(0):
+            return None
+        return raw[symbol]
+    if group_size == 1:
+        return raw
+    return None
+
+
+def _diag_summary(parts: Mapping[str, object]) -> str:
+    tokens: list[str] = []
+    for key in (
+        "chunk_count",
+        "batch_retry_count",
+        "batch_failure_count",
+        "fallback_symbol_count",
+        "recovered_symbol_count",
+        "final_failure_count",
+        "permanent_failure_count",
+        "transient_failure_count",
+        "source_universe_size",
+        "effective_universe_size",
+    ):
+        value = parts.get(key)
+        if value:
+            tokens.append(f"{key}={value}")
+    batch_reason_counts = parts.get("batch_reason_counts") or {}
+    symbol_reason_counts = parts.get("reason_counts") or {}
+    if batch_reason_counts:
+        tokens.append("batch_reasons=" + ",".join(f"{k}={v}" for k, v in sorted(batch_reason_counts.items())))
+    if symbol_reason_counts:
+        tokens.append("symbol_reasons=" + ",".join(f"{k}={v}" for k, v in sorted(symbol_reason_counts.items())))
+    return " ".join(tokens)
+
+
+def _failure_budget(reason_counts: Mapping[str, object]) -> dict[str, int]:
+    permanent = 0
+    transient = 0
+    for reason, count in reason_counts.items():
+        try:
+            amount = int(count)
+        except Exception:
+            continue
+        if reason in PERMANENT_LIQUIDITY_FAILURE_REASONS:
+            permanent += amount
+        elif amount > 0:
+            transient += amount
+    return {
+        "permanent_failure_count": permanent,
+        "transient_failure_count": transient,
+    }
+
+
+def chunks(values: list[str], size: int) -> list[list[str]]:
+    return [values[index : index + size] for index in range(0, len(values), size)]
+
+
+def liquidity_rows(
+    symbols: list[str],
+    chunk_size: int,
+    *,
+    batch_download: Callable[..., pd.DataFrame] | None = None,
+    session_factory: Callable[[], object | None] | None = None,
+    single_download: Callable[[str, str, str, int, float], tuple[pd.DataFrame | None, str]] | None = None,
+    batch_retries: int = DEFAULT_LIQUIDITY_BATCH_RETRIES,
+    symbol_retries: int = DEFAULT_LIQUIDITY_SYMBOL_RETRIES,
+    retry_sleep: float = DEFAULT_LIQUIDITY_RETRY_SLEEP,
+) -> pd.DataFrame:
+    if yf is None:
+        raise RuntimeError("yfinance is required to refresh the weekly liquid universe")
+    batch_download = batch_download or yf.download
+    session_factory = session_factory or core.new_yfinance_session
+    single_download = single_download or core.download_ohlcv
+    rows: list[dict[str, object]] = []
+    diagnostics: dict[str, object] = {
+        "chunk_count": 0,
+        "batch_retry_count": 0,
+        "batch_failure_count": 0,
+        "fallback_symbol_count": 0,
+        "recovered_symbol_count": 0,
+        "final_failure_count": 0,
+        "batch_reason_counts": Counter(),
+        "reason_counts": Counter(),
+    }
+    groups = chunks(symbols, max(1, chunk_size))
+    for number, group in enumerate(groups, start=1):
+        print(f"[weekly-universe] prices {number}/{len(groups)} ({len(group)} symbols)")
+        diagnostics["chunk_count"] = int(diagnostics["chunk_count"]) + 1
+        raw: pd.DataFrame | None = None
+        last_error = ""
+        attempts = max(1, int(batch_retries))
+        for attempt in range(1, attempts + 1):
+            try:
+                raw = batch_download(
+                    tickers=group,
+                    period="3mo",
+                    interval="1d",
+                    auto_adjust=False,
+                    group_by="ticker",
+                    threads=True,
+                    progress=False,
+                    session=session_factory(),
+                )
+            except Exception as exc:
+                raw = None
+                last_error = str(exc)
+            if raw is not None and not raw.empty:
+                break
+            reason = core.classify_yfinance_failure(last_error or "Empty response")
+            if attempt < attempts:
+                diagnostics["batch_retry_count"] = int(diagnostics["batch_retry_count"]) + 1
+                diagnostics["batch_reason_counts"][reason] += 1
+                print(f"[weekly-universe] batch retry {number}/{len(groups)} attempt={attempt} reason={reason}")
+                if retry_sleep > 0:
+                    time.sleep(retry_sleep * attempt)
+            else:
+                diagnostics["batch_failure_count"] = int(diagnostics["batch_failure_count"]) + 1
+                diagnostics["batch_reason_counts"][reason] += 1
+                print(f"[weekly-universe] batch failed {number}/{len(groups)} reason={reason}")
+
+        missing_symbols: list[str] = []
+        for symbol in group:
+            frame = _frame_from_raw(raw, symbol, len(group))
+            row, row_reason = _row_from_frame(symbol, frame)
+            if row is not None:
+                rows.append(row)
+                continue
+            missing_symbols.append(symbol)
+            diagnostics["fallback_symbol_count"] = int(diagnostics["fallback_symbol_count"]) + 1
+            data, err = single_download(symbol, "3mo", "1d", symbol_retries, retry_sleep)
+            row, row_reason = _row_from_frame(symbol, data)
+            if row is not None:
+                rows.append(row)
+                diagnostics["recovered_symbol_count"] = int(diagnostics["recovered_symbol_count"]) + 1
+                continue
+            reason = core.classify_yfinance_failure(err or row_reason or "No OHLCV data")
+            diagnostics["final_failure_count"] = int(diagnostics["final_failure_count"]) + 1
+            diagnostics["reason_counts"][reason] += 1
+            print(f"[weekly-universe] symbol failed {symbol} reason={reason}")
+
+        if missing_symbols and raw is not None and not raw.empty:
+            print(f"[weekly-universe] batch fallback {number}/{len(groups)} symbols={len(missing_symbols)}")
+
+    diagnostics["batch_reason_counts"] = dict(diagnostics["batch_reason_counts"])
+    diagnostics["reason_counts"] = dict(diagnostics["reason_counts"])
+    frame = pd.DataFrame(rows)
+    frame.attrs["liquidity_diagnostics"] = diagnostics
+    return frame
+
+
+def validate_liquid_universe(
+    universe_size: int,
+    liquid: pd.DataFrame,
+    *,
+    min_symbols: int,
+    min_coverage_pct: float,
+) -> tuple[bool, str, float]:
+    liquid_count = len(liquid)
+    coverage_pct = (liquid_count / universe_size * 100.0) if universe_size else 0.0
+    if universe_size <= 0:
+        return False, "source universe is empty", coverage_pct
+    if liquid_count <= 0:
+        return False, "no symbols survived price/liquidity filters", coverage_pct
+    if liquid_count < min_symbols:
+        return False, f"liquid symbol count {liquid_count} is below minimum {min_symbols}", coverage_pct
+    if coverage_pct < min_coverage_pct:
+        return False, f"liquid coverage {coverage_pct:.1f}% is below minimum {min_coverage_pct:.1f}%", coverage_pct
+    return True, "ok", coverage_pct
+
+
+def _stage_text(path: Path, text: str, encoding: str = "utf-8") -> Path:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with tempfile.NamedTemporaryFile(
+        "w",
+        delete=False,
+        dir=path.parent,
+        prefix=f".{path.name}.",
+        suffix=".tmp",
+        encoding=encoding,
+    ) as tmp:
+        tmp.write(text)
+        return Path(tmp.name)
+
+
+def _stage_csv(df: pd.DataFrame, path: Path) -> Path:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with tempfile.NamedTemporaryFile(
+        "w",
+        delete=False,
+        dir=path.parent,
+        prefix=f".{path.name}.",
+        suffix=".tmp",
+        encoding="utf-8-sig",
+        newline="",
+    ) as tmp:
+        staged = Path(tmp.name)
+    df.to_csv(staged, index=False, encoding="utf-8-sig")
+    return staged
+
+
+def _backup_target(path: Path) -> Path | None:
+    if not path.exists():
+        return None
+    with tempfile.NamedTemporaryFile(
+        "wb",
+        delete=False,
+        dir=path.parent,
+        prefix=f".{path.name}.",
+        suffix=".bak",
+    ) as tmp:
+        backup = Path(tmp.name)
+    shutil.copy2(path, backup)
+    return backup
+
+
+def publish_market_snapshot(
+    market: str,
+    liquid: pd.DataFrame,
+    output_dir: Path,
+    watchlist_dir: Path,
+    stamp: str,
+    universe_size: int,
+    coverage_pct: float,
+    source_provenance: Mapping[str, object],
+    replace_func: Callable[[Path, Path], None] = os.replace,
+) -> tuple[Path, Path, Path]:
+    market_key = market.lower()
+    dated = output_dir / f"{market_key}_liquid_{stamp}.csv"
+    current = output_dir / f"{market_key}_liquid_current.csv"
+    watchlist = watchlist_dir / f"{market_key}_daily_current.txt"
+    output_dir.mkdir(parents=True, exist_ok=True)
+    watchlist_dir.mkdir(parents=True, exist_ok=True)
+
+    published = liquid.copy()
+    published["universe_scope"] = WEEKLY_FULL_MARKET_SCOPE
+    published["universe_refreshed_at"] = datetime.now(timezone.utc).isoformat()
+    published["universe_symbol_count"] = universe_size
+    published["liquid_symbol_count"] = len(published)
+    published["liquidity_coverage_pct"] = round(coverage_pct, 2)
+    for column, value in snapshot_source_columns(source_provenance).items():
+        published[column] = value
+
+    watchlist_text = "\n".join(published["symbol"].astype(str)) + ("\n" if not published.empty else "")
+    staged: dict[Path, Path] = {}
+    backups: dict[Path, Path | None] = {}
+    published_targets: list[Path] = []
+    targets = (dated, watchlist, current)
+    try:
+        staged[dated] = _stage_csv(published, dated)
+        staged[current] = _stage_csv(published, current)
+        staged[watchlist] = _stage_text(watchlist, watchlist_text, encoding="utf-8")
+
+        for staged_csv in (staged[dated], staged[current]):
+            assessment = assess_weekly_universe_snapshot(staged_csv, market)
+            if assessment.status != "fresh":
+                raise ValueError(f"staged weekly snapshot validation failed: {assessment.reason}")
+        staged_symbols = staged[watchlist].read_text(encoding="utf-8").splitlines()
+        expected_symbols = published["symbol"].astype(str).tolist()
+        if staged_symbols != expected_symbols:
+            raise ValueError("staged watchlist symbols do not match staged snapshot")
+
+        for target in targets:
+            backups[target] = _backup_target(target)
+        # The current CSV is the commit marker and must be replaced last.
+        for target in targets:
+            replace_func(staged[target], target)
+            published_targets.append(target)
+    except Exception:
+        for target in reversed(targets):
+            backup = backups.get(target)
+            if backup is not None and backup.exists():
+                os.replace(backup, target)
+                backups[target] = None
+            elif target in published_targets and target.exists():
+                target.unlink()
+        raise
+    finally:
+        for temporary in [*staged.values(), *(path for path in backups.values() if path is not None)]:
+            if temporary.exists():
+                temporary.unlink()
+    return dated, current, watchlist
+
+
+def write_market(
+    market: str,
+    universe: pd.DataFrame,
+    output_dir: Path,
+    watchlist_dir: Path,
+    stamp: str,
+    min_dollar_volume: float,
+    min_close: float,
+    chunk_size: int,
+    metadata_workers: int,
+) -> dict[str, object]:
+    return write_market_with_loader(
+        market=market,
+        universe=universe,
+        output_dir=output_dir,
+        watchlist_dir=watchlist_dir,
+        stamp=stamp,
+        min_dollar_volume=min_dollar_volume,
+        min_close=min_close,
+        chunk_size=chunk_size,
+        metadata_workers=metadata_workers,
+        min_symbols=DEFAULT_MIN_SYMBOLS,
+        min_coverage_pct=DEFAULT_MIN_COVERAGE_PCT,
+        liquidity_source=liquidity_rows,
+    )
+
+
+def write_market_with_loader(
+    market: str,
+    universe: pd.DataFrame,
+    output_dir: Path,
+    watchlist_dir: Path,
+    stamp: str,
+    min_dollar_volume: float,
+    min_close: float,
+    chunk_size: int,
+    metadata_workers: int,
+    *,
+    min_symbols: int,
+    min_coverage_pct: float,
+    liquidity_source: Callable[[list[str], int], pd.DataFrame],
+) -> dict[str, object]:
+    market = market.upper()
+    source_provenance = universe.attrs.get("source_provenance")
+    provenance_ok, provenance_reason = validate_source_provenance(market, source_provenance)
+    if not provenance_ok:
+        reason = provenance_reason
+        print(f"[weekly-universe] {market} refresh skipped: {reason}; existing cache preserved")
+        return {
+            "market": market,
+            "ok": False,
+            "reason": reason,
+            "universe_size": len(universe),
+            "source_universe_size": len(universe),
+            "effective_universe_size": 0,
+            "liquid_size": 0,
+            "coverage_pct": 0.0,
+            "diagnostics": {},
+        }
+    universe = universe.copy()
+    source_universe_size = len(universe)
+    if source_universe_size == 0:
+        reason = "source universe is empty"
+        print(f"[weekly-universe] {market} refresh skipped: {reason}; existing cache preserved")
+        return {
+            "market": market,
+            "ok": False,
+            "reason": reason,
+            "universe_size": 0,
+            "source_universe_size": 0,
+            "effective_universe_size": 0,
+            "liquid_size": 0,
+            "coverage_pct": 0.0,
+            "diagnostics": {},
+        }
+
+    try:
+        liquidity = liquidity_source(universe["symbol"].astype(str).tolist(), chunk_size)
+    except Exception as exc:
+        reason = f"liquidity fetch failed: {exc}"
+        print(f"[weekly-universe] {market} refresh skipped: {reason}; existing cache preserved")
+        return {
+            "market": market,
+            "ok": False,
+            "reason": reason,
+            "universe_size": source_universe_size,
+            "source_universe_size": source_universe_size,
+            "effective_universe_size": 0,
+            "liquid_size": 0,
+            "coverage_pct": 0.0,
+            "diagnostics": {},
+        }
+
+    diagnostics = liquidity.attrs.get("liquidity_diagnostics") if hasattr(liquidity, "attrs") else None
+    if diagnostics:
+        diagnostics = dict(diagnostics)
+        diagnostics.update(_failure_budget(diagnostics.get("reason_counts") or {}))
+        diagnostics["source_universe_size"] = source_universe_size
+        summary = _diag_summary(diagnostics)
+        if summary:
+            print(f"[weekly-universe] {market} liquidity diagnostics: {summary}")
+    else:
+        diagnostics = {"source_universe_size": source_universe_size, **_failure_budget({})}
+
+    liquid = universe.merge(liquidity, on="symbol", how="inner")
+    analysis_ready = liquid[
+        liquid["close"].ge(min_close)
+        & liquid["liquidity_observations"].ge(10)
+        & liquid["average_dollar_volume_20d"].ge(max(0.0, min_dollar_volume * ANALYSIS_READY_LIQUIDITY_RATIO))
+    ].copy()
+    liquid = analysis_ready[
+        analysis_ready["average_dollar_volume_20d"].ge(min_dollar_volume)
+    ].copy()
+    if market == "KR" and not liquid.empty:
+        detail = liquid.apply(detail_for_row, axis=1, result_type="expand")
+        liquid["sector_detail"] = detail[0]
+        liquid["sector_detail_reason"] = detail[1]
+        liquid["sector_theme_group"] = liquid["sector_detail"].map(theme_group_for_detail)
+    if market == "US" and not liquid.empty:
+        info = enrich_sector_info(
+            liquid["symbol"].astype(str).tolist(),
+            output_dir / "us_sector_industry_cache.csv",
+            metadata_workers,
+        )
+        liquid = liquid.drop(columns=["sector"], errors="ignore").merge(
+            info[["symbol", "sector", "industry", "source"]], on="symbol", how="left"
+        )
+    liquid = liquid.sort_values("average_dollar_volume_20d", ascending=False).reset_index(drop=True)
+
+    transient_failure_count = int((diagnostics or {}).get("transient_failure_count", 0))
+    permanent_failure_count = int((diagnostics or {}).get("permanent_failure_count", 0))
+    analysis_ready_universe_size = len(analysis_ready)
+    if transient_failure_count > 0:
+        transient_reasons = {
+            key: int(value)
+            for key, value in sorted((diagnostics or {}).get("reason_counts", {}).items())
+            if key not in PERMANENT_LIQUIDITY_FAILURE_REASONS and int(value) > 0
+        }
+        reason = "liquidity fetch had transient failures: " + ", ".join(
+            f"{key}={value}" for key, value in transient_reasons.items()
+        )
+        print(
+            f"[weekly-universe] {market} refresh skipped: {reason}; "
+            f"source_universe={source_universe_size} existing cache preserved"
+        )
+        return {
+            "market": market,
+            "ok": False,
+            "reason": reason,
+            "universe_size": analysis_ready_universe_size,
+            "source_universe_size": source_universe_size,
+            "effective_universe_size": analysis_ready_universe_size,
+            "liquid_size": len(liquid),
+            "coverage_pct": 0.0,
+            "diagnostics": diagnostics or {},
+        }
+
+    ok, reason, coverage_pct = validate_liquid_universe(
+        analysis_ready_universe_size,
+        liquid,
+        min_symbols=min_symbols,
+        min_coverage_pct=min_coverage_pct,
+    )
+    if not ok:
+        print(
+            f"[weekly-universe] {market} refresh skipped: {reason}; "
+            f"source_universe={source_universe_size} analysis_ready_universe={analysis_ready_universe_size} "
+            f"liquid={len(liquid)} coverage={coverage_pct:.1f}% existing cache preserved"
+        )
+        return {
+            "market": market,
+            "ok": False,
+            "reason": reason,
+            "universe_size": analysis_ready_universe_size,
+            "source_universe_size": source_universe_size,
+            "effective_universe_size": analysis_ready_universe_size,
+            "liquid_size": len(liquid),
+            "coverage_pct": round(coverage_pct, 2),
+            "diagnostics": diagnostics or {},
+        }
+
+    dated, current, watchlist = publish_market_snapshot(
+        market=market,
+        liquid=liquid,
+        output_dir=output_dir,
+        watchlist_dir=watchlist_dir,
+        stamp=stamp,
+        universe_size=analysis_ready_universe_size,
+        coverage_pct=coverage_pct,
+        source_provenance=source_provenance,
+    )
+    print(
+        f"[weekly-universe] {market} published source_universe={source_universe_size} analysis_ready_universe={analysis_ready_universe_size} liquid={len(liquid)} "
+        f"coverage={coverage_pct:.1f}% current={current} watchlist={watchlist}"
+    )
+    return {
+        "market": market,
+        "ok": True,
+        "reason": "published",
+        "universe_size": analysis_ready_universe_size,
+        "source_universe_size": source_universe_size,
+        "effective_universe_size": analysis_ready_universe_size,
+        "liquid_size": len(liquid),
+        "coverage_pct": round(coverage_pct, 2),
+        "dated": dated,
+        "current": current,
+        "watchlist": watchlist,
+        "diagnostics": diagnostics or {},
+    }
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description="Refresh weekly liquid leadership universes and daily watchlists.")
+    parser.add_argument("--market", choices=["both", "kr", "us"], default="both")
+    parser.add_argument("--output-dir", type=Path, default=REPO_ROOT / "universes")
+    parser.add_argument("--watchlist-dir", type=Path, default=REPO_ROOT / "watchlists")
+    parser.add_argument("--chunk-size", type=int, default=DEFAULT_LIQUIDITY_CHUNK_SIZE)
+    parser.add_argument("--metadata-workers", type=int, default=8)
+    parser.add_argument("--min-symbols", type=int, default=DEFAULT_MIN_SYMBOLS)
+    parser.add_argument("--min-coverage-pct", type=float, default=DEFAULT_MIN_COVERAGE_PCT)
+    parser.add_argument("--kr-min-traded-value", type=float, default=1_000_000_000)
+    parser.add_argument("--us-min-dollar-volume", type=float, default=2_000_000)
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+    stamp = datetime.now().strftime("%Y%m%d")
+    failures = 0
+    if args.market in {"both", "kr"}:
+        try:
+            kr_universe = get_kr_universe()
+        except Exception as exc:
+            print(f"[weekly-universe] KR universe load failed: {exc}; existing cache preserved")
+            failures += 1
+        else:
+            try:
+                result = write_market_with_loader(
+                    "KR", kr_universe, args.output_dir, args.watchlist_dir, stamp,
+                    args.kr_min_traded_value, 1_000.0, args.chunk_size, args.metadata_workers,
+                    min_symbols=args.min_symbols,
+                    min_coverage_pct=args.min_coverage_pct,
+                    liquidity_source=liquidity_rows,
+                )
+            except Exception as exc:
+                print(f"[weekly-universe] KR refresh failed unexpectedly: {exc}; existing cache preserved")
+                failures += 1
+            else:
+                failures += 0 if result.get("ok") else 1
+    if args.market in {"both", "us"}:
+        try:
+            us_universe = get_us_universe(include_etf=False)
+        except Exception as exc:
+            print(f"[weekly-universe] US universe load failed: {exc}; existing cache preserved")
+            failures += 1
+        else:
+            try:
+                result = write_market_with_loader(
+                    "US", us_universe, args.output_dir, args.watchlist_dir, stamp,
+                    args.us_min_dollar_volume, 2.0, args.chunk_size, args.metadata_workers,
+                    min_symbols=args.min_symbols,
+                    min_coverage_pct=args.min_coverage_pct,
+                    liquidity_source=liquidity_rows,
+                )
+            except Exception as exc:
+                print(f"[weekly-universe] US refresh failed unexpectedly: {exc}; existing cache preserved")
+                failures += 1
+            else:
+                failures += 0 if result.get("ok") else 1
+    return 0 if failures == 0 else 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
