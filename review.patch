+        self.assertTrue(out["recommend_bucket"].str.contains("바이오텍").all())
+
+    def test_rs_unknown_or_below_ema21_is_not_practical(self) -> None:
+        rows = pd.DataFrame(
+            [
+                candidate(symbol="UNKNOWN", rs_score=None, rs_above_ma=None),
+                candidate(symbol="BELOW", rs_above_ma=False),
+            ]
