+class RecommendationGateTests(unittest.TestCase):
+    def test_biotech_is_observation_only(self) -> None:
+        rows = pd.DataFrame(
+            [
+                candidate(symbol="QTTB", stock_name="Q32 Bio", industry="Biotechnology"),
