+class BusinessDirectnessTests(unittest.TestCase):
+    def setUp(self) -> None:
+        self.leadership = pd.DataFrame(
+            [
+                {"sector": "Semiconductors", "leadership_score": 88.0, "leadership_grade": "주도"},
+                {"sector": "AI Infrastructure", "leadership_score": 81.0, "leadership_grade": "주도"},
+                {"sector": "Software", "leadership_score": 79.0, "leadership_grade": "강세"},
+            ]
+        )
+
+    def test_ebay_and_dbd_are_not_ai_direct_from_software_word(self) -> None:
+        rows = [
+            pd.Series(
+                {
+                    "symbol": "EBAY",
+                    "sector": "Consumer Cyclical",
+                    "industry": "Internet Retail",
+                    "business_summary": "Operates an online marketplace using software tools.",
+                }
+            ),
+            pd.Series(
+                {
+                    "symbol": "DBD",
+                    "sector": "Industrials",
+                    "industry": "Business Equipment",
+                    "business_summary": "Provides cash automation software and retail banking equipment.",
+                }
+            ),
+        ]
+
+        for row in rows:
+            result = classify_business_directness(row, self.leadership)
+            self.assertEqual(result.business_directness, "unrelated")
+            self.assertEqual(result.matched_lead_sector, "")
+            self.assertTrue(result.needs_sector_review)
+
+    def test_mtsi_is_direct_when_semiconductors_are_actually_leading(self) -> None:
+        result = classify_business_directness(
+            pd.Series(
+                {
+                    "symbol": "MTSI",
+                    "sector": "Technology",
+                    "industry": "Semiconductors",
+                    "business_summary": "Designs high-performance RF, optical and data-center semiconductors.",
+                }
+            ),
+            self.leadership,
+        )
+
+        self.assertEqual(result.business_directness, "direct")
+        self.assertEqual(result.matched_lead_sector, "Semiconductors")
+        self.assertFalse(result.needs_sector_review)
+        self.assertEqual(result.sector_leadership_score, 88.0)
+
+    def test_ambiguous_match_requires_review(self) -> None:
+        result = classify_business_directness(
+            pd.Series(
+                {
+                    "symbol": "AMB",
+                    "sector": "Technology",
+                    "industry": "Technology Services",
+                    "business_summary": "Provides next-generation technology solutions.",
