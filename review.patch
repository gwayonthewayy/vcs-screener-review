+"""Canonical selection policy shared by VCS briefing outputs.
+
+This module intentionally contains no network or delivery code.  It turns already
+collected market, sector, fundamentals, chart and RS data into deterministic
+selection fields used by markdown, Telegram and TradingView exporters.
+"""
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Mapping, Sequence
+import re
+
+import numpy as np
+import pandas as pd
+
+
+DIRECTNESS_POINTS = {"direct": 10.0, "adjacent": 6.0, "peripheral": 2.0, "unrelated": 0.0}
+EARNINGS_POINTS = {
+    "profitable_expansion": 20.0,
+    "profitable_slowdown": 14.0,
+    "turnaround_positive": 12.0,
+    "loss_narrowing": 5.0,
+    "distorted_or_missing": 0.0,
+}
+PRACTICAL_EARNINGS = {"profitable_expansion", "profitable_slowdown", "turnaround_positive"}
+FRESH_LEADERSHIP_SCOPE = "weekly_liquid_full_market_fresh"
+BIOTECH_PATTERN = re.compile(
+    r"\b(?:biotech(?:nology)?|therapeutics?|clinical[- ]stage|drug development|oncology|rare disease)\b|바이오텍|신약",
+    re.IGNORECASE,
+)
+GENERIC_BUSINESS_TOKENS = {
+    "and", "for", "the", "technology", "technologies", "services", "solutions",
+    "software", "systems", "industrial", "industrials", "business", "company",
+}
+
+
+@dataclass(frozen=True)
+class RecommendationPolicy:
+    min_vcs: float = 45.0
+    min_sector_leadership_score: float = 60.0
+    max_below_ma50_pct: float = 10.0
+    max_ma50_extension_pct: float = 20.0
+    max_earnings_age_days: int = 180
+    max_atrp: float = 9.0
+    fresh_leadership_scopes: tuple[str, ...] = (FRESH_LEADERSHIP_SCOPE,)
+
+
+@dataclass(frozen=True)
+class BusinessMatch:
+    business_directness: str
+    matched_lead_sector: str
+    sector_leadership_score: float | None
+    needs_sector_review: bool
+    match_reason: str
+
+
+@dataclass(frozen=True)
+class EarningsAssessment:
+    quality: str
+    verified: bool
+    quarter: str
+    release_date: str
+    source_type: str
+    age_days: int | None
+    reason: str
+
+
+@dataclass(frozen=True)
+class MarketExposure:
+    signal: str
+    score: float
+    exposure_multiplier: float
+    reasons: tuple[str, ...]
+
+
+def _clean(value: object) -> str:
+    if value is None or (isinstance(value, float) and pd.isna(value)):
+        return ""
+    return " ".join(str(value).split())
+
+
+def _number(value: object) -> float | None:
+    try:
+        number = float(value)
+    except (TypeError, ValueError):
+        return None
+    return None if pd.isna(number) else number
+
+
+def _boolean(value: object) -> bool | None:
+    if value is None or (isinstance(value, float) and pd.isna(value)):
+        return None
+    if isinstance(value, (bool, np.bool_)):
+        return bool(value)
+    text = str(value).strip().lower()
+    if text in {"true", "1", "yes", "y", "t"}:
+        return True
+    if text in {"false", "0", "no", "n", "f"}:
+        return False
+    return None
+
+
+def _tokens(value: object) -> set[str]:
+    return {
+        token
+        for token in re.findall(r"[a-z0-9가-힣]+", _clean(value).replace("_", " ").replace("/", " ").lower())
+        if len(token) > 2 and token not in GENERIC_BUSINESS_TOKENS
+    }
+
+
+def _business_text(row: pd.Series) -> str:
+    fields = [
+        "sector", "sector_detail", "sector_theme_group", "industry", "business_summary",
+        "longBusinessSummary", "business_description", "description", "theme_hint", "business_tags",
+    ]
+    return " ".join(_clean(row.get(field)) for field in fields if _clean(row.get(field))).lower()
+
+
+def _canonical_evidence(text: str) -> set[str]:
+    evidence: set[str] = set()
+    rules: dict[str, Sequence[str]] = {
+        "semiconductors": ("semiconductor", "chip design", "rf chip", "hbm", "반도체", "웨이퍼", "파운드리"),
+        "ai infrastructure": ("ai accelerator", "gpu server", "data center networking", "artificial intelligence infrastructure", "ai infrastructure", "ai 인프라"),
+        "software": ("saas", "cloud software", "enterprise software", "cybersecurity", "application software"),
+        "shipbuilding": ("shipbuilding", "shipyard", "조선", "선박", "특수선"),
+        "power infrastructure": ("transformer", "power grid", "switchgear", "전력기기", "변압기", "전력망"),
+        "biotechnology": ("biotech", "biotechnology", "therapeutics", "clinical-stage", "바이오텍", "신약"),
+    }
+    for label, phrases in rules.items():
+        if any(phrase in text for phrase in phrases):
+            evidence.add(label)
+    return evidence
+
+
+def classify_business_directness(row: pd.Series, leadership: pd.DataFrame) -> BusinessMatch:
+    """Match real business evidence only against sectors that are currently leading."""
+    if leadership is None or leadership.empty or "sector" not in leadership.columns:
+        return BusinessMatch("unrelated", "", None, True, "sector leadership unavailable")
+
+    leaders = leadership.copy()
+    leaders["leadership_score"] = pd.to_numeric(leaders.get("leadership_score"), errors="coerce")
+    leaders = leaders.dropna(subset=["leadership_score"]).sort_values("leadership_score", ascending=False)
+    if leaders.empty:
+        return BusinessMatch("unrelated", "", None, True, "sector leadership score unavailable")
+
+    business_text = _business_text(row)
+    business_tokens = _tokens(business_text)
+    evidence = _canonical_evidence(business_text)
+    structured = " ".join(
+        _clean(row.get(field)).lower()
+        for field in ("sector", "sector_detail", "sector_theme_group", "industry", "business_tags")
+    )
+    generic_overlap_seen = False
+
+    best: tuple[int, float, BusinessMatch] | None = None
+    for _, leader in leaders.iterrows():
+        sector = _clean(leader.get("sector"))
+        if not sector:
+            continue
+        score = float(leader["leadership_score"])
+        sector_lower = sector.lower()
+        leader_tokens = _tokens(sector_lower)
+        canonical = _canonical_evidence(sector_lower)
+
+        sector_tokens = _tokens(sector_lower)
+        exact_structured = bool(sector_tokens) and all(token in structured for token in sector_tokens)
+        canonical_match = bool(canonical & evidence)
+        specific_overlap = leader_tokens & business_tokens
+        generic_overlap_seen = generic_overlap_seen or bool(_tokens(sector) & _tokens(business_text))
+
+        if exact_structured or canonical_match:
+            result = BusinessMatch("direct", sector, score, False, "structured industry/business evidence matches current leader")
+            rank = 4
+        elif len(specific_overlap) >= 2:
+            result = BusinessMatch("adjacent", sector, score, False, "multiple specific business terms overlap current leader")
+            rank = 3
+        elif specific_overlap:
+            result = BusinessMatch("peripheral", sector, score, True, "single business-term overlap needs review")
+            rank = 2
+        else:
+            continue
+        candidate = (rank, score, result)
+        if best is None or candidate[:2] > best[:2]:
+            best = candidate
+
+    if best is not None:
+        return best[2]
+    reason = "generic technology wording is not direct business evidence" if generic_overlap_seen or "technology" in business_text else "no business evidence matches a current leader"
+    return BusinessMatch("unrelated", "", None, True, reason)
+
+
+def _first(row: pd.Series, names: Sequence[str]) -> object:
+    for name in names:
+        value = row.get(name)
+        if value is not None and not (isinstance(value, float) and pd.isna(value)) and _clean(value):
+            return value
+    return None
+
+
+def classify_earnings_quality(
+    row: pd.Series,
+    *,
+    as_of: pd.Timestamp | None = None,
+    max_age_days: int = 180,
+) -> EarningsAssessment:
+    as_of = (as_of or pd.Timestamp.now()).normalize()
+    quarter = _clean(_first(row, ("earnings_quarter", "announced_quarter", "earnings_quarter_end", "quarter_end", "latest_quarter")))
+    release_raw = _first(row, ("earnings_release_date", "release_date", "announced_release_date"))
+    source = _clean(_first(row, ("earnings_source_type", "earnings_release_source", "release_source", "earnings_basis"))).lower()
+    release = pd.to_datetime(release_raw, errors="coerce")
+    age_days = None if pd.isna(release) else max(0, int((as_of - release.normalize()).days))
+    source_verified = any(term in source for term in ("official", "provisional", "preliminary", "dart", "sec", "공식", "잠정"))
+
+    revenue = _number(_first(row, ("revenue_current", "announced_revenue_current", "quarter_revenue")))
+    latest = _number(row.get("opm_latest_q"))
+    one_year = _number(row.get("opm_roll4q"))
+    three_year = _number(row.get("opm_roll12q"))
+    metadata_ok = bool(quarter and age_days is not None and age_days <= max_age_days and source_verified)
+    values_ok = revenue is not None and revenue > 0 and latest is not None and one_year is not None and three_year is not None
+    if not metadata_ok or not values_ok:
+        reason = "missing/stale release metadata" if not metadata_ok else "revenue or OPM missing/distorted"
+        return EarningsAssessment(
+            "distorted_or_missing", False, quarter, "" if pd.isna(release) else release.date().isoformat(),
+            source, age_days, reason,
+        )
+
+    if latest < 0 and one_year < 0 and three_year < 0:
+        quality = "loss_narrowing" if latest > one_year > three_year else "distorted_or_missing"
+    elif latest >= 0 and one_year <= 0:
+        quality = "turnaround_positive"
+    elif latest > 0 and one_year > 0 and three_year > 0 and latest >= one_year > three_year:
+        quality = "profitable_expansion"
+    elif latest > 0 and one_year > 0 and three_year > 0:
+        quality = "profitable_slowdown"
+    else:
+        quality = "distorted_or_missing"
+    verified = quality != "distorted_or_missing"
+    return EarningsAssessment(
+        quality, verified, quarter, release.date().isoformat(), source, age_days,
+        "latest reported quarter classified from revenue and OPM history",
+    )
+
+
+def _component_scores(row: pd.Series) -> dict[str, float]:
+    sector_score = _number(row.get("sector_leadership_score")) or 0.0
+    directness = _clean(row.get("business_directness")) or "unrelated"
+    earnings = _clean(row.get("earnings_quality")) or "distorted_or_missing"
+    latest_opm = _number(row.get("opm_latest_q"))
+    one_year_opm = _number(row.get("opm_roll4q"))
+    vcs = _number(row.get("vcs_score")) or 0.0
+    base = _clean(row.get("base_quality_label"))
+    rs = _number(row.get("rs_score")) or 0.0
+    ma_gap = _number(row.get("ma50_gap_pct"))
+    atrp = _number(row.get("atrp14"))
+    dollar_volume = _number(row.get("average_dollar_volume_20d"))
+
+    if latest_opm is None or one_year_opm is None:
+        opm_points = 0.0
+    elif latest_opm >= 20 and one_year_opm > 0:
+        opm_points = 15.0
+    elif latest_opm >= 10 and one_year_opm > 0:
+        opm_points = 12.0
+    elif latest_opm > 3 and one_year_opm > 0:
+        opm_points = 8.0
+    elif latest_opm >= 0:
+        opm_points = 4.0
+    else:
+        opm_points = 0.0
+
+    if ma_gap is None:
+        entry_points = 0.0
+    elif 0 <= ma_gap <= 8:
+        entry_points = 5.0
+    elif 8 < ma_gap <= 15:
+        entry_points = 3.0
+    elif -10 <= ma_gap < 0:
+        entry_points = 1.0
+    else:
+        entry_points = 0.0
+
+    liquidity_points = 0.0
+    if atrp is not None and atrp <= 6:
+        liquidity_points += 2.0
+    elif atrp is not None and atrp <= 9:
+        liquidity_points += 1.0
+    if dollar_volume is not None:
+        liquidity_points += 3.0 if dollar_volume >= 10_000_000 else 2.0 if dollar_volume >= 2_000_000 else 0.0
+    elif atrp is not None:
+        liquidity_points += 1.0
+
+    vcs_points = min(12.0, max(0.0, (vcs - 45.0) / 55.0 * 12.0))
+    base_points = {"tight": 3.0, "constructive": 2.0, "needs_chart_review": 1.0}.get(base, 0.0)
+
+    return {
+        "score_sector_leadership": min(15.0, max(0.0, sector_score) * 0.15),
+        "score_business_directness": DIRECTNESS_POINTS.get(directness, 0.0),
+        "score_earnings_quality": EARNINGS_POINTS.get(earnings, 0.0),
+        "score_opm_quality": min(15.0, opm_points),
+        "score_vcs_base": min(15.0, vcs_points + base_points),
+        "score_rs": min(15.0, max(0.0, rs) * 0.15),
+        "score_entry_position": entry_points,
+        "score_liquidity_risk": min(5.0, liquidity_points),
+    }
+
+
+def enrich_recommendations(
+    df: pd.DataFrame,
+    *,
+    policy: RecommendationPolicy | None = None,
+) -> pd.DataFrame:
+    policy = policy or RecommendationPolicy()
+    if df.empty:
+        return df.copy()
+
+    rows: list[dict[str, object]] = []
+    for _, source in df.iterrows():
+        row = source.copy()
+        text = _business_text(row) + " " + _clean(row.get("stock_name")).lower()
+        biotech = bool(BIOTECH_PATTERN.search(text))
+        business = _clean(row.get("business_directness")) or "unrelated"
+        needs_review = _boolean(row.get("needs_sector_review")) is not False
+        earnings = _clean(row.get("earnings_quality")) or "distorted_or_missing"
+        earnings_verified = _boolean(row.get("earnings_verified")) is True
+        vcs = _number(row.get("vcs_score"))
+        rs_score = _number(row.get("rs_score"))
+        rs_above = _boolean(row.get("rs_above_ma"))
+        ma_gap = _number(row.get("ma50_gap_pct"))
+        if ma_gap is None:
+            close = _number(row.get("close"))
+            ma50 = _number(row.get("ma50"))
+            ma_gap = (close / ma50 - 1.0) * 100.0 if close is not None and ma50 and ma50 > 0 else None
+        atrp = _number(row.get("atrp14"))
+        base = _clean(row.get("base_quality_label"))
+        opm_distorted = _boolean(row.get("is_loss_or_opm_distorted")) is True or earnings in {"loss_narrowing", "distorted_or_missing"}
+        leadership_scope = _clean(row.get("leadership_universe_scope")) or "unknown"
+        sector_score = _number(row.get("sector_leadership_score"))
+
+        failures: list[str] = []
+        if vcs is None or vcs < policy.min_vcs:
+            failures.append("VCS 게이트 미통과")
+        if leadership_scope not in policy.fresh_leadership_scopes:
+            failures.append(f"주도섹터 scope 미검증({leadership_scope})")
+        if sector_score is None:
+            failures.append("주도섹터 점수 미확인")
+        elif sector_score < policy.min_sector_leadership_score:
+            failures.append(
+                f"주도섹터 점수 미달({sector_score:.1f} < {policy.min_sector_leadership_score:.1f})"
+            )
+        if business not in {"direct", "adjacent"} or needs_review:
+            failures.append("사업 직접성 미검증")
+        if not earnings_verified or earnings not in PRACTICAL_EARNINGS:
+            failures.append("최신 실적 미검증")
+        if rs_score is None:
+            failures.append("RS미확인")
+        elif rs_above is not True:
+            failures.append("RS Line EMA21 하방")
+        if ma_gap is None:
+            failures.append("MA50 위치 미확인")
+        elif ma_gap < -policy.max_below_ma50_pct:
+            failures.append("MA50 하단 10% 초과")
+        elif ma_gap < 0:
+            failures.append("MA50 회복 대기")
+        elif ma_gap > policy.max_ma50_extension_pct:
+            failures.append("과도한 MA50 이격")
+        if base in {"extended", "volatile", "deep_or_loose", "weak_vcs"}:
+            failures.append("베이스/이격 리스크")
+        if atrp is not None and atrp > policy.max_atrp:
+            failures.append("변동성 과다")
+        if biotech:
+            failures.append("고위험 바이오텍")
+        if opm_distorted:
+            failures.append("OPM 왜곡/적자")
+
+        practical = not failures
+        scores = _component_scores(row)
+        observation_score = round(min(100.0, sum(scores.values())), 4)
+        immediate = practical and ma_gap is not None and ma_gap >= 0
+
+        if biotech:
+            bucket = "비주도/고위험 / 바이오텍"
+            stance = "관찰"
+        elif ma_gap is not None and -policy.max_below_ma50_pct <= ma_gap < 0:
+            bucket = "관찰 후보"
+            stance = "MA50 회복 대기"
+        elif practical:
+            bucket = "실전 추천 후보"
+            stance = "돌파 대기"
+        elif ma_gap is not None and ma_gap > policy.max_ma50_extension_pct:
+            bucket = "관찰 후보"
+            stance = "눌림 대기"
+        else:
+            bucket = "관찰 후보"
+            stance = "관찰"
+
+        result = row.to_dict()
+        result.update(scores)
+        result.update(
+            {
+                "ma50_gap_pct": ma_gap,
+                "is_biotech_or_high_risk": biotech,
+                "is_loss_or_opm_distorted": opm_distorted,
+                "is_rs_unconfirmed_or_weak": rs_score is None or rs_above is not True,
+                "is_extended_or_risky": ma_gap is None or ma_gap > policy.max_ma50_extension_pct or base in {"extended", "volatile"},
+                "is_practical_recommendation": practical,
+                "immediate_buy_ok": immediate,
+                "trade_stance": stance,
+                "recommend_bucket": bucket,
+                "recommend_reason": "실전 추천 하드 게이트 통과" if practical else ", ".join(dict.fromkeys(failures)),
+                "observation_score": observation_score,
+                "recommend_score": observation_score if practical else np.nan,
+                "recommend_score_method": "v2_gate_then_weighted_100",
+            }
+        )
+        rows.append(result)
+
+    out = pd.DataFrame(rows)
+    out["_practical_order"] = out["is_practical_recommendation"].astype(int)
+    out = out.sort_values(
+        ["_practical_order", "recommend_score", "observation_score", "vcs_score"],
+        ascending=[False, False, False, False], na_position="last",
+    ).drop(columns="_practical_order")
+    return out.reset_index(drop=True)
+
+
+def canonical_practical_candidates(df: pd.DataFrame, *, limit: int | None = None) -> pd.DataFrame:
+    required = {"is_practical_recommendation", "recommend_score"}
+    missing = sorted(required - set(df.columns))
+    if missing:
+        raise ValueError(f"candidate schema missing required practical fields: {', '.join(missing)}")
+    mask = df["is_practical_recommendation"].map(_boolean).eq(True)
+    out = df[mask].copy()
+    out["recommend_score"] = pd.to_numeric(out["recommend_score"], errors="coerce")
+    if out["recommend_score"].isna().any():
+        raise ValueError("practical candidate has missing recommend_score")
+    tie_breakers = [name for name in ("recommend_score", "vcs_score", "symbol") if name in out.columns]
+    ascending = [False if name != "symbol" else True for name in tie_breakers]
+    out = out.sort_values(tie_breakers, ascending=ascending, na_position="last")
+    if limit is not None:
+        out = out.head(limit)
+    return out.reset_index(drop=True)
+
+
+def _point_value(point: object, field: str) -> float | None:
+    if isinstance(point, Mapping):
+        return _number(point.get(field))
+    return _number(getattr(point, field, None))
+
+
+def assess_market_exposure(points: Mapping[str, object]) -> MarketExposure:
+    """Score only available market evidence; missing data is neutral."""
+    if not points:
+        return MarketExposure("데이터 부족", 0.0, 1.0, ("시장 데이터 N/A: 노출 중립 처리",))
+
+    score = 0.0
+    evidence = 0
+    reasons: list[str] = []
+    index_labels = ("KOSPI", "KOSDAQ", "S&P500 ETF", "Nasdaq100 ETF", "Semiconductor ETF")
+    for label in index_labels:
+        point = points.get(label)
+        if point is None:
+            continue
+        for field, weight, title in (("ma20_gap", 0.5, "MA20"), ("ma50_gap", 0.8, "MA50"), ("ma200_gap", 1.0, "MA200")):
+            value = _point_value(point, field)
+            if value is None:
+                continue
+            evidence += 1
+            score += weight if value >= 0 else -weight
+            reasons.append(f"{label} {title} {'상방' if value >= 0 else '하방'}({value:+.1f}%)")
+        for field, weight, title in (("pct_5d", 0.4, "5D"), ("pct_20d", 0.6, "20D")):
+            value = _point_value(point, field)
+            if value is None:
+                continue
+            evidence += 1
+            score += weight if value >= 0 else -weight
+            reasons.append(f"{label} {title} {value:+.1f}%")
+
+    vix = points.get("VIX")
+    vix_close = _point_value(vix, "close") if vix is not None else None
+    vix_change = _point_value(vix, "pct_5d") if vix is not None else None
+    if vix_close is not None:
+        evidence += 1
+        score += 0.8 if vix_close < 18 else 0.0 if vix_close < 23 else -1.0
+        reasons.append(f"VIX {vix_close:.1f}, 5D {vix_change:+.1f}%" if vix_change is not None else f"VIX {vix_close:.1f}")
+
+    fx = points.get("USDKRW")
+    fx_close = _point_value(fx, "close") if fx is not None else None
+    fx_change = _point_value(fx, "pct_20d") if fx is not None else None
+    if fx_close is not None:
+        evidence += 1
+        fx_penalty = -0.8 if fx_close >= 1450 else -0.3 if fx_close >= 1380 else 0.2
+        if fx_change is not None and fx_change > 2:
+            fx_penalty -= 0.4
+        score += fx_penalty
+        reasons.append(f"USDKRW {fx_close:.1f}, 20D {fx_change:+.1f}%" if fx_change is not None else f"USDKRW {fx_close:.1f}")
+
+    if evidence == 0:
+        return MarketExposure("데이터 부족", 0.0, 1.0, ("시장 데이터 N/A: 노출 중립 처리",))
+    if score >= 5:
+        signal, exposure = "공격 가능", 1.0
+    elif score >= 1:
+        signal, exposure = "선별 가능", 0.75
+    elif score > -2:
+        signal, exposure = "중립/확인", 0.55
+    else:
+        signal, exposure = "방어", 0.35
+    return MarketExposure(signal, round(score, 2), exposure, tuple(reasons))
