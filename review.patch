+def _component_scores(row: pd.Series) -> dict[str, float]:
+    sector_score = _number(row.get("sector_leadership_score")) or 0.0
+    directness = _clean(row.get("business_directness")) or "unrelated"
+    earnings = _clean(row.get("earnings_quality")) or "distorted_or_missing"
+    latest_opm = _number(row.get("opm_latest_q"))
+    one_year_opm = _number(row.get("opm_roll4q"))
+    vcs = _number(row.get("vcs_score")) or 0.0
+    base = _clean(row.get("base_quality_label"))
+    rs = _number(row.get("rs_score")) or 0.0
+    ma_gap = _number(row.get("ma50_gap_pct"))
+    atrp = _number(row.get("atrp14"))
+    dollar_volume = _number(row.get("average_dollar_volume_20d"))
+
+    if latest_opm is None or one_year_opm is None:
+        opm_points = 0.0
+    elif latest_opm >= 20 and one_year_opm > 0:
+        opm_points = 15.0
+    elif latest_opm >= 10 and one_year_opm > 0:
+        opm_points = 12.0
+    elif latest_opm > 3 and one_year_opm > 0:
+        opm_points = 8.0
+    elif latest_opm >= 0:
+        opm_points = 4.0
+    else:
+        opm_points = 0.0
+
+    if ma_gap is None:
+        entry_points = 0.0
+    elif 0 <= ma_gap <= 8:
+        entry_points = 5.0
+    elif 8 < ma_gap <= 15:
+        entry_points = 3.0
+    elif -10 <= ma_gap < 0:
+        entry_points = 1.0
+    else:
+        entry_points = 0.0
+
+    liquidity_points = 0.0
+    if atrp is not None and atrp <= 6:
+        liquidity_points += 2.0
+    elif atrp is not None and atrp <= 9:
+        liquidity_points += 1.0
+    if dollar_volume is not None:
+        liquidity_points += 3.0 if dollar_volume >= 10_000_000 else 2.0 if dollar_volume >= 2_000_000 else 0.0
+    elif atrp is not None:
+        liquidity_points += 1.0
+
+    vcs_points = min(12.0, max(0.0, (vcs - 45.0) / 55.0 * 12.0))
+    base_points = {"tight": 3.0, "constructive": 2.0, "needs_chart_review": 1.0}.get(base, 0.0)
+
+    return {
+        "score_sector_leadership": min(15.0, max(0.0, sector_score) * 0.15),
+        "score_business_directness": DIRECTNESS_POINTS.get(directness, 0.0),
+        "score_earnings_quality": EARNINGS_POINTS.get(earnings, 0.0),
+        "score_opm_quality": min(15.0, opm_points),
+        "score_vcs_base": min(15.0, vcs_points + base_points),
+        "score_rs": min(15.0, max(0.0, rs) * 0.15),
+        "score_entry_position": entry_points,
+        "score_liquidity_risk": min(5.0, liquidity_points),
+    }
+
+
+def enrich_recommendations(
+    df: pd.DataFrame,
+    *,
+    policy: RecommendationPolicy | None = None,
+) -> pd.DataFrame:
+    policy = policy or RecommendationPolicy()
+    if df.empty:
+        return df.copy()
+
+    rows: list[dict[str, object]] = []
+    for _, source in df.iterrows():
+        row = source.copy()
+        text = _risk_business_text(row) + " " + _clean(row.get("stock_name")).lower()
+        biotech = bool(BIOTECH_PATTERN.search(text))
+        business = _clean(row.get("business_directness")) or "unrelated"
+        needs_review = _boolean(row.get("needs_sector_review")) is not False
+        earnings = _clean(row.get("earnings_quality")) or "distorted_or_missing"
+        earnings_verified = _boolean(row.get("earnings_verified")) is True
+        vcs = _number(row.get("vcs_score"))
+        rs_score = _number(row.get("rs_score"))
+        rs_above = _boolean(row.get("rs_above_ma"))
+        ma_gap = _number(row.get("ma50_gap_pct"))
+        if ma_gap is None:
+            close = _number(row.get("close"))
+            ma50 = _number(row.get("ma50"))
+            ma_gap = (close / ma50 - 1.0) * 100.0 if close is not None and ma50 and ma50 > 0 else None
+        atrp = _number(row.get("atrp14"))
+        base = _clean(row.get("base_quality_label"))
+        opm_distorted = _boolean(row.get("is_loss_or_opm_distorted")) is True or earnings in {"loss_narrowing", "distorted_or_missing"}
+        leadership_scope = _clean(row.get("leadership_universe_scope")) or "unknown"
+        sector_score = _number(row.get("sector_leadership_score"))
+
+        failures: list[str] = []
+        if vcs is None or vcs < policy.min_vcs:
+            failures.append("VCS 게이트 미통과")
+        if leadership_scope not in policy.fresh_leadership_scopes:
+            failures.append(f"주도섹터 scope 미검증({leadership_scope})")
+        if sector_score is None:
+            failures.append("주도섹터 점수 미확인")
+        elif sector_score < policy.min_sector_leadership_score:
+            failures.append(
+                f"주도섹터 점수 미달({sector_score:.1f} < {policy.min_sector_leadership_score:.1f})"
+            )
+        if business not in {"direct", "adjacent"} or needs_review:
+            failures.append("사업 직접성 미검증")
+        if not earnings_verified or earnings not in PRACTICAL_EARNINGS:
+            failures.append("최신 실적 미검증")
+        if rs_score is None:
+            failures.append("RS미확인")
+        elif rs_above is not True:
+            failures.append("RS Line EMA21 하방")
+        if ma_gap is None:
+            failures.append("MA50 위치 미확인")
+        elif ma_gap < -policy.max_below_ma50_pct:
+            failures.append("MA50 하단 10% 초과")
+        elif ma_gap < 0:
+            failures.append("MA50 회복 대기")
+        elif ma_gap > policy.max_ma50_extension_pct:
+            failures.append("과도한 MA50 이격")
+        if base in {"extended", "volatile", "deep_or_loose", "weak_vcs"}:
+            failures.append("베이스/이격 리스크")
+        if atrp is not None and atrp > policy.max_atrp:
+            failures.append("변동성 과다")
+        if biotech:
+            failures.append("고위험 바이오텍")
+        if opm_distorted:
+            failures.append("OPM 왜곡/적자")
+
+        practical = not failures
+        scores = _component_scores(row)
+        observation_score = round(min(100.0, sum(scores.values())), 4)
+        immediate = practical and ma_gap is not None and ma_gap >= 0
+
+        if biotech:
+            bucket = "비주도/고위험 / 바이오텍"
+            stance = "관찰"
+        elif ma_gap is not None and -policy.max_below_ma50_pct <= ma_gap < 0:
+            bucket = "관찰 후보"
+            stance = "MA50 회복 대기"
+        elif practical:
+            bucket = "실전 추천 후보"
+            stance = "돌파 대기"
+        elif ma_gap is not None and ma_gap > policy.max_ma50_extension_pct:
+            bucket = "관찰 후보"
+            stance = "눌림 대기"
+        else:
+            bucket = "관찰 후보"
+            stance = "관찰"
+
+        result = row.to_dict()
+        result.update(scores)
+        result.update(
+            {
+                "ma50_gap_pct": ma_gap,
+                "is_biotech_or_high_risk": biotech,
+                "is_loss_or_opm_distorted": opm_distorted,
+                "is_rs_unconfirmed_or_weak": rs_score is None or rs_above is not True,
+                "is_extended_or_risky": ma_gap is None or ma_gap > policy.max_ma50_extension_pct or base in {"extended", "volatile"},
+                "is_practical_recommendation": practical,
+                "immediate_buy_ok": immediate,
+                "trade_stance": stance,
+                "recommend_bucket": bucket,
+                "recommend_reason": "실전 추천 하드 게이트 통과" if practical else ", ".join(dict.fromkeys(failures)),
+                "observation_score": observation_score,
+                "recommend_score": observation_score if practical else np.nan,
+                "recommend_score_method": "v2_gate_then_weighted_100",
+            }
+        )
+        rows.append(result)
+
+    out = pd.DataFrame(rows)
+    out["_practical_order"] = out["is_practical_recommendation"].astype(int)
+    out = out.sort_values(
+        ["_practical_order", "recommend_score", "observation_score", "vcs_score"],
+        ascending=[False, False, False, False], na_position="last",
+    ).drop(columns="_practical_order")
+    return out.reset_index(drop=True)
+
+
+def canonical_practical_candidates(df: pd.DataFrame, *, limit: int | None = None) -> pd.DataFrame:
+    required = {"is_practical_recommendation", "recommend_score"}
+    missing = sorted(required - set(df.columns))
+    if missing:
+        raise ValueError(f"candidate schema missing required practical fields: {', '.join(missing)}")
+    mask = df["is_practical_recommendation"].map(_boolean).eq(True)
+    out = df[mask].copy()
+    out["recommend_score"] = pd.to_numeric(out["recommend_score"], errors="coerce")
+    if out["recommend_score"].isna().any():
+        raise ValueError("practical candidate has missing recommend_score")
+    tie_breakers = [name for name in ("recommend_score", "vcs_score", "symbol") if name in out.columns]
+    ascending = [False if name != "symbol" else True for name in tie_breakers]
+    out = out.sort_values(tie_breakers, ascending=ascending, na_position="last")
+    if limit is not None:
+        out = out.head(limit)
+    return out.reset_index(drop=True)
+
