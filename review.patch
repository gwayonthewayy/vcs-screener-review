+def _point_value(point: object, field: str) -> float | None:
+    if isinstance(point, Mapping):
+        return _number(point.get(field))
+    return _number(getattr(point, field, None))
+
+
+def assess_market_exposure(points: Mapping[str, object]) -> MarketExposure:
+    """Score only available market evidence; missing data is neutral."""
+    if not points:
+        return MarketExposure("데이터 부족", 0.0, 1.0, ("시장 데이터 N/A: 노출 중립 처리",))
+
+    score = 0.0
+    evidence = 0
+    reasons: list[str] = []
+    index_labels = ("KOSPI", "KOSDAQ", "S&P500 ETF", "Nasdaq100 ETF", "Semiconductor ETF")
+    for label in index_labels:
+        point = points.get(label)
+        if point is None:
+            continue
+        for field, weight, title in (("ma20_gap", 0.5, "MA20"), ("ma50_gap", 0.8, "MA50"), ("ma200_gap", 1.0, "MA200")):
+            value = _point_value(point, field)
+            if value is None:
+                continue
+            evidence += 1
+            score += weight if value >= 0 else -weight
+            reasons.append(f"{label} {title} {'상방' if value >= 0 else '하방'}({value:+.1f}%)")
+        for field, weight, title in (("pct_5d", 0.4, "5D"), ("pct_20d", 0.6, "20D")):
+            value = _point_value(point, field)
+            if value is None:
+                continue
+            evidence += 1
+            score += weight if value >= 0 else -weight
+            reasons.append(f"{label} {title} {value:+.1f}%")
+
+    vix = points.get("VIX")
+    vix_close = _point_value(vix, "close") if vix is not None else None
+    vix_change = _point_value(vix, "pct_5d") if vix is not None else None
+    if vix_close is not None:
+        evidence += 1
+        score += 0.8 if vix_close < 18 else 0.0 if vix_close < 23 else -1.0
+        reasons.append(f"VIX {vix_close:.1f}, 5D {vix_change:+.1f}%" if vix_change is not None else f"VIX {vix_close:.1f}")
+
+    fx = points.get("USDKRW")
+    fx_close = _point_value(fx, "close") if fx is not None else None
+    fx_change = _point_value(fx, "pct_20d") if fx is not None else None
+    if fx_close is not None:
+        evidence += 1
+        fx_penalty = -0.8 if fx_close >= 1450 else -0.3 if fx_close >= 1380 else 0.2
+        if fx_change is not None and fx_change > 2:
+            fx_penalty -= 0.4
+        score += fx_penalty
+        reasons.append(f"USDKRW {fx_close:.1f}, 20D {fx_change:+.1f}%" if fx_change is not None else f"USDKRW {fx_close:.1f}")
+
+    if evidence == 0:
+        return MarketExposure("데이터 부족", 0.0, 1.0, ("시장 데이터 N/A: 노출 중립 처리",))
+    if score >= 5:
+        signal, exposure = "공격 가능", 1.0
+    elif score >= 1:
+        signal, exposure = "선별 가능", 0.75
+    elif score > -2:
+        signal, exposure = "중립/확인", 0.55
+    else:
+        signal, exposure = "방어", 0.35
+    return MarketExposure(signal, round(score, 2), exposure, tuple(reasons))
