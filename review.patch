+def universe_frame(size: int = 10) -> pd.DataFrame:
+    rows = []
+    for idx in range(size):
+        symbol = f"{idx:06d}.KS"
+        rows.append(
+            {
+                "market": "KR",
+                "symbol": symbol,
+                "stock_name": f"Name {idx}",
+                "sector": "Technology",
+            }
+        )
+    return pd.DataFrame(rows)
+
+
+def liquid_frame(symbols: list[str]) -> pd.DataFrame:
+    return pd.DataFrame(
+        [
+            {
+                "symbol": symbol,
+                "close": 1_500.0 + idx,
+                "average_dollar_volume_20d": 25_000_000.0 + idx,
+                "liquidity_observations": 20,
+            }
+            for idx, symbol in enumerate(symbols)
+        ]
+    )
+
+
+class WeeklyUniverseRefreshTests(unittest.TestCase):
+    def test_full_fetch_failure_preserves_existing_cache(self) -> None:
+        with TemporaryDirectory() as tmp:
+            root = Path(tmp)
+            output_dir = root / "universes"
+            watchlist_dir = root / "watchlists"
+            output_dir.mkdir()
+            watchlist_dir.mkdir()
+            current = output_dir / "kr_liquid_current.csv"
+            watchlist = watchlist_dir / "kr_daily_current.txt"
+            current.write_text("OLD\n", encoding="utf-8-sig")
+            watchlist.write_text("OLD\n", encoding="utf-8")
+            before_mtime = current.stat().st_mtime_ns
+
+            result = refresh.write_market_with_loader(
+                "KR",
+                universe_frame(),
+                output_dir,
+                watchlist_dir,
+                "20260619",
+                1_000_000_000.0,
+                1_000.0,
+                5,
+                1,
+                min_symbols=3,
+                min_coverage_pct=50.0,
+                liquidity_source=lambda symbols, chunk_size: (_ for _ in ()).throw(RuntimeError("boom")),
+            )
+
+            self.assertFalse(result["ok"])
+            self.assertEqual(current.read_text(encoding="utf-8-sig"), "OLD\n")
+            self.assertEqual(watchlist.read_text(encoding="utf-8"), "OLD\n")
+            self.assertEqual(current.stat().st_mtime_ns, before_mtime)
+
+    def test_zero_results_preserve_existing_cache(self) -> None:
+        with TemporaryDirectory() as tmp:
+            root = Path(tmp)
+            output_dir = root / "universes"
+            watchlist_dir = root / "watchlists"
+            output_dir.mkdir()
+            watchlist_dir.mkdir()
+            current = output_dir / "kr_liquid_current.csv"
+            watchlist = watchlist_dir / "kr_daily_current.txt"
+            current.write_text("OLD\n", encoding="utf-8-sig")
+            watchlist.write_text("OLD\n", encoding="utf-8")
+
+            result = refresh.write_market_with_loader(
+                "KR",
+                universe_frame(),
+                output_dir,
+                watchlist_dir,
+                "20260619",
+                1_000_000_000.0,
+                1_000.0,
+                5,
+                1,
+                min_symbols=3,
+                min_coverage_pct=50.0,
+                liquidity_source=lambda symbols, chunk_size: pd.DataFrame(
+                    columns=["symbol", "close", "average_dollar_volume_20d", "liquidity_observations"]
+                ),
+            )
+
+            self.assertFalse(result["ok"])
+            self.assertIn("no symbols", str(result["reason"]))
+            self.assertEqual(current.read_text(encoding="utf-8-sig"), "OLD\n")
+            self.assertEqual(watchlist.read_text(encoding="utf-8"), "OLD\n")
+
+    def test_low_coverage_preserves_existing_cache(self) -> None:
+        with TemporaryDirectory() as tmp:
+            root = Path(tmp)
+            output_dir = root / "universes"
+            watchlist_dir = root / "watchlists"
+            output_dir.mkdir()
+            watchlist_dir.mkdir()
+            current = output_dir / "kr_liquid_current.csv"
