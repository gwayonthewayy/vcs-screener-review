+        self.assertTrue(out["recommend_reason"].str.contains("RS").all())
+
+    def test_ma50_minus_ten_percent_is_retained_but_not_immediate(self) -> None:
+        rows = pd.DataFrame([candidate(close=91.0, ma50=100.0, ma50_gap_pct=-9.0)])
+        out = enrich_recommendations(rows)
+        self.assertEqual(len(out), 1)
+        self.assertEqual(out.iloc[0]["trade_stance"], "MA50 회복 대기")
+        self.assertFalse(bool(out.iloc[0]["immediate_buy_ok"]))
+
+    def test_sector_leadership_changes_recommend_score(self) -> None:
+        rows = pd.DataFrame(
+            [
+                candidate(symbol="LEADER", sector_leadership_score=90.0),
+                candidate(symbol="LAGGARD", sector_leadership_score=70.0),
+            ]
+        )
+        out = enrich_recommendations(rows).set_index("symbol")
+        self.assertGreater(out.loc["LEADER", "recommend_score"], out.loc["LAGGARD", "recommend_score"])
+        self.assertLessEqual(out["recommend_score"].max(), 100.0)
+
+    def test_fresh_scope_and_sector_score_gate_practical(self) -> None:
+        rows = pd.DataFrame(
+            [
+                candidate(
+                    symbol="TOO_WEAK",
+                    sector_leadership_score=59.0,
+                    leadership_universe_scope="weekly_liquid_full_market_fresh",
+                ),
+                candidate(
+                    symbol="JUST_OK",
+                    sector_leadership_score=60.0,
+                    leadership_universe_scope="weekly_liquid_full_market_fresh",
+                ),
+                candidate(
+                    symbol="STALE",
+                    sector_leadership_score=90.0,
+                    leadership_universe_scope="stale_cached_market_context",
+                ),
+                candidate(
+                    symbol="FALLBACK",
+                    sector_leadership_score=90.0,
+                    leadership_universe_scope="candidate_fallback_not_full_market",
+                ),
+            ]
+        )
+        out = enrich_recommendations(rows).set_index("symbol")
+        self.assertFalse(bool(out.loc["TOO_WEAK", "is_practical_recommendation"]))
+        self.assertIn("59.0 < 60.0", str(out.loc["TOO_WEAK", "recommend_reason"]))
+        self.assertTrue(bool(out.loc["JUST_OK", "is_practical_recommendation"]))
+        self.assertFalse(bool(out.loc["STALE", "is_practical_recommendation"]))
+        self.assertIn("scope", str(out.loc["STALE", "recommend_reason"]))
+        self.assertFalse(bool(out.loc["FALLBACK", "is_practical_recommendation"]))
+        self.assertIn("scope", str(out.loc["FALLBACK", "recommend_reason"]))
+
+    def test_practical_top_does_not_backfill_observations(self) -> None:
+        rows = [candidate(symbol=f"GOOD{i}", vcs_score=70 + i) for i in range(3)]
+        rows.extend(candidate(symbol=f"OBS{i}", rs_above_ma=False, vcs_score=99 - i) for i in range(5))
+        enriched = enrich_recommendations(pd.DataFrame(rows))
+        top = canonical_practical_candidates(enriched, limit=10)
+        self.assertEqual(len(top), 3)
+        self.assertEqual(set(top["symbol"]), {"GOOD0", "GOOD1", "GOOD2"})
+
+    def test_missing_practical_column_fails_closed(self) -> None:
+        with self.assertRaises(ValueError):
+            canonical_practical_candidates(pd.DataFrame([{"symbol": "X", "recommend_score": 99.0}]))
